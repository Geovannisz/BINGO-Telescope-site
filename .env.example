# This is an example of the environment variables used by the BINGO Telescope Site
# Copy this file to `.env` and adjust the values according to your environment.

# Target deployment domain used for canonical URLs and SEO JSON-LD structured data
# Default (if not set): https://bingotelescope.org
SITE_URL=https://bingotelescope.org

# Base path for hosting on root domain or subdirectory
# Note: For custom domains (CNAME) like bingotelescope.org, leave this empty or set to `/`
BASE_PATH=/
