---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'pt' | 'en' | 'zh';
}

const { title, description = "BINGO Telescope - Baryon Acoustic Oscillations from Integrated Neutral Gas Observations", lang = 'pt' } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | BINGO Telescope</title>
    <meta name="description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Netlify Identity Widget (required by Decap CMS admin panel) -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body class="bg-slate-900 text-slate-200 font-sans min-h-screen flex flex-col antialiased selection:bg-cyan-500/30">
    <Header lang={lang} />
    <main class="flex-grow pt-20"> <!-- pt-20 to account for fixed header -->
      <slot />
    </main>
    <Footer />

    <script>
      import { onAuthChange, AUTH_EVENTS } from '@netlify/identity';
      onAuthChange((event) => {
        if (event === AUTH_EVENTS.LOGIN) {
          document.location.href = import.meta.env.BASE_URL + 'admin/';
        }
      });
    </script>
  </body>
</html>
