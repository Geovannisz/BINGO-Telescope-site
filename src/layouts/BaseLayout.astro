---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'pt' | 'en' | 'zh';
}

const { title, description = "BINGO Telescope - Baryon Acoustic Oscillations from Integrated Neutral Gas Observations. Radiotelescópio em Aguiar, Paraíba, Brasil.", lang = 'pt' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | BINGO Telescope</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="BINGO, telescope, radio telescope, BAO, baryon acoustic oscillations, intensity mapping, dark energy, hydrogen, 21cm, cosmology, Paraíba, Brazil, FRB, fast radio bursts, ABDUS, Uirapuru" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | BINGO Telescope`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${base}images/telescope/BINGO_model_1.jpeg`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | BINGO Telescope`} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts: Inter (body) + Outfit (headings) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <!-- NOTE: Netlify Identity Widget is loaded only in /admin/index.html, not globally.
         This avoids CORS errors on public pages while keeping the CMS functional. -->
  </head>
  <body class="bg-cosmic text-slate-200 font-sans min-h-screen flex flex-col antialiased selection:bg-cyan-500/30">
    <Header lang={lang} />
    <main class="flex-grow pt-20"> <!-- pt-20 to account for fixed header -->
      <slot />
    </main>
    <Footer />

    <script is:inline>

      // Scroll-triggered animations via IntersectionObserver
      document.addEventListener('DOMContentLoaded', function() {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        document.querySelectorAll('.animate-on-scroll').forEach(function(el) {
          observer.observe(el);
        });

        // ===== BINGO Brand Font Auto-Wrapper =====
        // Automatically wraps all visible occurrences of "BINGO" in <span class="font-bingo">
        // to apply the Nasalization™ font. Skips: scripts, styles, meta, already-wrapped text.
        (function applyBingoFont() {
          var SKIP_TAGS = { SCRIPT: 1, STYLE: 1, NOSCRIPT: 1, TEXTAREA: 1, CODE: 1, PRE: 1, SVG: 1 };
          var walker = document.createTreeWalker(
            document.body,
            NodeFilter.SHOW_TEXT,
            {
              acceptNode: function(node) {
                var parent = node.parentElement;
                if (!parent) return NodeFilter.FILTER_REJECT;
                if (SKIP_TAGS[parent.tagName]) return NodeFilter.FILTER_REJECT;
                if (parent.classList && parent.classList.contains('font-bingo')) return NodeFilter.FILTER_REJECT;
                if (node.textContent && node.textContent.indexOf('BINGO') !== -1) return NodeFilter.FILTER_ACCEPT;
                return NodeFilter.FILTER_REJECT;
              }
            }
          );

          var textNodes = [];
          while (walker.nextNode()) textNodes.push(walker.currentNode);

          textNodes.forEach(function(textNode) {
            var parts = textNode.textContent.split(/(BINGO-ABDUS|BINGO)/g);
            if (parts.length <= 1) return;
            var frag = document.createDocumentFragment();
            parts.forEach(function(part) {
              if (part === 'BINGO' || part === 'BINGO-ABDUS') {
                var span = document.createElement('span');
                span.className = 'font-bingo';
                span.textContent = part;
                frag.appendChild(span);
              } else if (part) {
                frag.appendChild(document.createTextNode(part));
              }
            });
            textNode.parentNode.replaceChild(frag, textNode);
          });
        })();
      });
    </script>
  </body>
</html>
