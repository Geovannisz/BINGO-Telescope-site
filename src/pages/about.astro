---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Sobre o Projeto" nativeI18n pageId="about">
  <!-- Page Header with WMAP background -->
  <div class="relative py-24 overflow-hidden section-bg-image" style="min-height: 40vh;">
    <div class="bg-img" style={`background-image: url('${base}images/backgrounds/WMAP_2012-background.png'); opacity: 0.15;`}></div>
    <div class="bg-overlay" style="background: linear-gradient(180deg, rgba(7,13,31,0.5) 0%, rgba(15,23,42,0.85) 70%, #0f172a 100%);"></div>
    <div class="starfield"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-3xl animate-fade-in-up">
        <p class="section-label" data-t="header.label">Sobre</p>
        <h1 class="text-4xl font-black tracking-tight text-white sm:text-6xl" style="font-family: 'Outfit', sans-serif;" data-t="header.title">Sobre o Projeto <span class="gradient-text-cyan">BINGO</span></h1>
        <p class="mt-6 text-lg leading-8 text-slate-300" data-t="header.desc">
          O BINGO (Baryon Acoustic Oscillations from Integrated Neutral Gas Observations) é um radiotelescópio inovador projetado para explorar as profundezas do universo e buscar respostas para a natureza da Energia Escura — o componente misterioso que constitui ~68% do conteúdo energético do cosmos.
        </p>
      </div>
    </div>
  </div>

  <div class="bg-cosmic pb-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">

      <!-- Mission and Objectives -->
      <div class="md:flex gap-12 items-center mb-20 animate-on-scroll">
        <div class="md:w-1/2 mb-8 md:mb-0">
          <div class="rounded-2xl overflow-hidden border border-indigo-500/15 shadow-2xl shadow-cyan-500/5">
            <img src={`${base}images/BINGO-construcao.jpg`} alt="Construção do Telescópio BINGO" class="w-full h-auto" />
          </div>
        </div>
        <div class="md:w-1/2">
          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-3" style="font-family: 'Outfit', sans-serif;">
            <div class="feature-icon">
              <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
            <span data-t="mission.title">Missão e Objetivos</span>
          </h2>
          <p class="text-slate-300 leading-relaxed mb-4" data-t="mission.p1">
            Concebido no início da década de 2010 como um projeto colaborativo internacional, o BINGO visa realizar a <strong class="text-cyan-400">primeira detecção de Oscilações Acústicas de Bárions (BAO) em frequências de rádio</strong>, utilizando a técnica inovadora de Intensity Mapping da linha de emissão de 21cm do hidrogênio neutro (HI).
          </p>
          <p class="text-slate-300 leading-relaxed mb-4" data-t="mission.p2">
            Operando na faixa de 980 MHz a 1260 MHz, o BINGO cobrirá o intervalo de redshift 0.127 ≤ z ≤ 0.449 — correspondendo a sinais emitidos quando o universo tinha entre 72% e 88% de sua idade atual. Este mapeamento fornecerá uma <strong class="text-white">régua padrão independente</strong> para medir a expansão do universo.
          </p>
          <p class="text-slate-300 leading-relaxed" data-t="mission.p3">
            Além da ciência primária de BAO, o BINGO terá capacidade de detectar <strong class="text-cyan-400">Fast Radio Bursts (FRBs)</strong>, monitorar pulsares, e contribuir para estudos de foreground galáctico e física fundamental — tornando-o um dos instrumentos mais versáteis da rádio-astronomia brasileira.
          </p>
        </div>
      </div>

      <!-- International Consortium -->
      <div class="md:flex gap-12 items-center flex-row-reverse mb-20 animate-on-scroll">
        <div class="md:w-1/2 mb-8 md:mb-0">
          <div class="rounded-2xl overflow-hidden border border-indigo-500/15 relative bg-slate-900/50" style="height: 400px; min-height: 400px;" id="paraiba-map-container">
            <div id="paraiba-map" class="w-full h-full z-0"></div>
          </div>
        </div>
        <div class="md:w-1/2">
          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-3" style="font-family: 'Outfit', sans-serif;">
            <div class="feature-icon">
              <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
            </div>
            <span data-t="consortium.title">Consórcio Internacional</span>
          </h2>
          <div class="flex flex-wrap gap-3 mb-6">
            <img src="https://flagcdn.com/br.svg" alt="Brasil" class="h-8 w-auto rounded-sm shadow-md" title="Brasil" />
            <img src="https://flagcdn.com/cn.svg" alt="China" class="h-8 w-auto rounded-sm shadow-md" title="China" />
            <img src="https://flagcdn.com/gb.svg" alt="Reino Unido" class="h-8 w-auto rounded-sm shadow-md" title="Reino Unido" />
            <img src="https://flagcdn.com/fr.svg" alt="França" class="h-8 w-auto rounded-sm shadow-md" title="França" />
            <img src="https://flagcdn.com/nl.svg" alt="Holanda" class="h-8 w-auto rounded-sm shadow-md" title="Holanda" />
            <img src="https://flagcdn.com/za.svg" alt="África do Sul" class="h-8 w-auto rounded-sm shadow-md" title="África do Sul" />
          </div>
          <p class="text-slate-300 leading-relaxed mb-4" data-t="consortium.p1">
            O BINGO é liderado pelo <strong class="text-white">Brasil</strong> — com destaque para a Universidade de São Paulo (USP/IF), o Instituto Nacional de Pesquisas Espaciais (INPE) e a Universidade Federal de Campina Grande (UFCG) — em forte parceria com instituições de múltiplos países.
          </p>
          <p class="text-slate-300 leading-relaxed mb-4" data-t="consortium.p2">
            A <strong class="text-white">China</strong> é parceira crucial, contribuindo com fabricação de componentes estruturais e expertise em engenharia de radiotelescópios. O <strong class="text-white">Reino Unido</strong> (Manchester, UCL), a <strong class="text-white">França</strong> (Observatório de Paris, Nançay) e a <strong class="text-white">Holanda</strong> (ASTRON) contribuem com design de receptores, processamento de sinais e expertise em interferometria.
          </p>
          <p class="text-slate-300 leading-relaxed" data-t="consortium.p3">
            O telescópio está sendo construído na <strong class="text-cyan-400">Serra do Urubu, em Aguiar, Paraíba</strong> — uma região escolhida por sua baixíssima interferência de radiofrequência (RFI), latitude ideal (~7°S) para observações do hemisfério sul, e topografia natural que oferece proteção adicional contra ruído eletromagnético.
          </p>
        </div>
      </div>

      <!-- Liderança Científica -->
      <div class="glass-card-glow p-8 md:p-12 mb-20 animate-on-scroll">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-2xl font-bold text-white mb-6" style="font-family: 'Outfit', sans-serif;" data-t="leadership.title">Liderança Científica</h2>
          <div class="section-divider"></div>
          <p class="text-slate-300 leading-relaxed mb-4" data-t="leadership.p1">
            O projeto BINGO foi concebido e liderado pelo Prof. <strong class="text-cyan-400">Elcio Abdalla</strong> (IF-USP), um dos mais renomados físicos teóricos e cosmólogos do Brasil, com contribuições fundamentais para a compreensão da energia escura e da estrutura em larga escala do universo.
          </p>
          <p class="text-slate-300 leading-relaxed mb-4" data-t="leadership.p2">
            A coordenação técnica e instrumental é liderada pelo Prof. <strong class="text-white">Carlos Alexandre Wuensche</strong> (INPE), responsável pelo design dos receptores, cornetas e pelo desenvolvimento do protótipo BINGO-Uirapuru. O consórcio conta com mais de <strong class="text-cyan-400">60 pesquisadores</strong> espalhados por mais de 20 instituições em 7 países.
          </p>
          <p class="text-slate-300 leading-relaxed" data-t="leadership.p3">
            O nome da extensão "BINGO-ABDUS" homenageia tanto o acrônimo funcional (Advanced BINGO Dark Universe Studies) quanto o legado do físico paquistanês <strong class="text-white">Abdus Salam</strong>, laureado com o Prêmio Nobel de Física de 1979 por sua contribuição à teoria eletrofraca.
          </p>
        </div>
      </div>

      <!-- Timeline -->
      <div class="max-w-3xl mx-auto animate-on-scroll">
        <h2 class="text-2xl font-bold text-white mb-8 text-center" style="font-family: 'Outfit', sans-serif;" data-t="timeline.title">Linha do Tempo do Projeto</h2>
        <div class="section-divider"></div>
        <div class="timeline mt-8">
          <div class="timeline-item">
            <div class="timeline-year">2012</div>
            <div class="timeline-text" data-t="timeline.2012">Concepção do projeto BINGO como um radiotelescópio dedicado à detecção de BAO via Intensity Mapping de 21cm do hidrogênio neutro. Proposta inicial apresentada pela colaboração Brasil-Reino Unido.</div>
          </div>
          <div class="timeline-item">
            <div class="timeline-year">2014</div>
            <div class="timeline-text" data-t="timeline.2014">Início dos estudos de viabilidade, seleção do design óptico Crossed-Dragone, e primeiras simulações de performance científica. Definição dos requisitos de sensibilidade para detecção de BAO.</div>
          </div>
          <div class="timeline-item">
            <div class="timeline-year">2017</div>
            <div class="timeline-text" data-t="timeline.2017">Seleção definitiva do site na Serra do Urubu, Aguiar, Paraíba, após extensas campanhas de medição de RFI. A região demonstrou níveis excepcionalmente baixos de interferência eletromagnética.</div>
          </div>
          <div class="timeline-item">
            <div class="timeline-year">2019</div>
            <div class="timeline-text" data-t="timeline.2019">Construção e teste do protótipo da corneta corrugada broadband. Publicação do paper de fabricação (Wuensche et al., 2019). Validação do diagrama de radiação e resposta em frequência.</div>
          </div>
          <div class="timeline-item">
            <div class="timeline-year">2020</div>
            <div class="timeline-text" data-t="timeline.2020">Instalação do BINGO-Uirapuru no campus da UFCG em Campina Grande, como testbed de receptores, backend digital e software de processamento de dados.</div>
          </div>
          <div class="timeline-item">
            <div class="timeline-year">2022</div>
            <div class="timeline-text" data-t="timeline.2022">Publicação da série de 8 artigos "The BINGO Project" (Papers I–VIII) na Astronomy &amp; Astrophysics — detalhando ciência, instrumento, simulações de foreground, calibração, e previsões cosmológicas abrangentes.</div>
          </div>
          <div class="timeline-item">
            <div class="timeline-year">2023</div>
            <div class="timeline-text" data-t="timeline.2023">Lançamento oficial do consórcio BINGO-ABDUS (Advanced BINGO Dark Universe Studies) em parceria com ASTRON (Holanda) e Observatório de Nançay (França). Início do desenvolvimento de antenas phased-array Vivaldi.</div>
          </div>
          <div class="timeline-item">
            <div class="timeline-year">2024</div>
            <div class="timeline-text" data-t="timeline.2024">Paper IX publicado: proposta do BINGO Interferometry System (BIS) com outriggers para detecção e localização de Fast Radio Bursts. Fabricação da estrutura principal na China.</div>
          </div>
          <div class="timeline-item">
            <div class="timeline-year">2025</div>
            <div class="timeline-text" data-t="timeline.2025">Transporte da estrutura para o Brasil e início da montagem no site de Aguiar. Paper X publicado com previsões cosmológicas atualizadas. Desenvolvimento contínuo de tiles phased-array Vivaldi.</div>
          </div>
          <div class="timeline-item">
            <div class="timeline-year">2026</div>
            <div class="timeline-text" data-t="timeline.2026">Fase de comissionamento e calibração do telescópio. Primeiras observações científicas previstas. Integração dos receptores e validação do pipeline de processamento de dados.</div>
          </div>
        </div>
      </div>

      <!-- Publications Overview -->
      <div class="mt-24 pt-16 border-t border-indigo-500/10 animate-on-scroll">
        <div class="text-center mb-12">
          <p class="section-label" data-t="publications.label">Produção Científica</p>
          <h2 class="text-2xl font-bold text-white" style="font-family: 'Outfit', sans-serif;" data-t="publications.title">Série de Artigos "The BINGO Project"</h2>
          <div class="section-divider mt-4"></div>
          <p class="text-slate-400 max-w-2xl mx-auto" data-t="publications.desc">O consórcio publicou uma série abrangente de artigos científicos na revista Astronomy &amp; Astrophysics, documentando todos os aspectos do projeto.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="info-card p-4"><p class="text-sm"><strong class="text-cyan-400">Paper I</strong> — <span class="text-slate-300" data-t="paper1">Visão geral do projeto e objetivos científicos</span></p></div>
          <div class="info-card p-4"><p class="text-sm"><strong class="text-cyan-400">Paper II</strong> — <span class="text-slate-300" data-t="paper2">Design do instrumento e simulações ópticas</span></p></div>
          <div class="info-card p-4"><p class="text-sm"><strong class="text-cyan-400">Paper III</strong> — <span class="text-slate-300" data-t="paper3">Otimização do plano focal e layout das cornetas</span></p></div>
          <div class="info-card p-4"><p class="text-sm"><strong class="text-cyan-400">Paper IV</strong> — <span class="text-slate-300" data-t="paper4">Simulações de foreground e component separation</span></p></div>
          <div class="info-card p-4"><p class="text-sm"><strong class="text-cyan-400">Paper V</strong> — <span class="text-slate-300" data-t="paper5">Efeitos de calibração e sistemáticos</span></p></div>
          <div class="info-card p-4"><p class="text-sm"><strong class="text-cyan-400">Paper VI</strong> — <span class="text-slate-300" data-t="paper6">Pipeline de map-making e power spectrum</span></p></div>
          <div class="info-card p-4"><p class="text-sm"><strong class="text-cyan-400">Paper VII</strong> — <span class="text-slate-300" data-t="paper7">Previsões cosmológicas para BAO e w₀/wₐ</span></p></div>
          <div class="info-card p-4"><p class="text-sm"><strong class="text-cyan-400">Paper VIII</strong> — <span class="text-slate-300" data-t="paper8">Mapeamento de HI e foreground removal</span></p></div>
          <div class="info-card p-4"><p class="text-sm"><strong class="text-cyan-400">Paper IX</strong> — <span class="text-slate-300" data-t="paper9">BINGO Interferometry System (BIS) para FRBs</span></p></div>
          <div class="info-card p-4"><p class="text-sm"><strong class="text-cyan-400">Paper X</strong> — <span class="text-slate-300" data-t="paper10">Previsões atualizadas e BINGO-ABDUS</span></p></div>
        </div>

        <div class="mt-8 text-center">
          <a href={`${base}publications`} class="inline-flex items-center text-cyan-400 hover:text-cyan-300 font-medium transition-colors">
            <span data-t="publications.link">Ver todas as publicações</span>
            <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
        </div>
      </div>

    </div>
  </div>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      if (!window.L) return;

      const map = L.map('paraiba-map', {
        scrollWheelZoom: false, // Disabled by default, enabled on Ctrl
        dragging: !L.Browser.mobile, // Prevent scroll trapping on mobile
        zoomControl: true
      });

      // Add Satellite TileLayer
      L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
        attribution: 'Tiles &copy; Esri',
        maxZoom: 17
      }).addTo(map);

      // Fetch Paraíba GeoJSON from IBGE
      fetch('https://servicodados.ibge.gov.br/api/v3/malhas/estados/25?formato=application/vnd.geo+json')
        .then(res => res.json())
        .then(data => {
          const pbLayer = L.geoJSON(data, {
            style: {
              color: '#22d3ee',
              weight: 3,
              fillColor: '#0ea5e9',
              fillOpacity: 0.05,
              className: 'pb-border-glow'
            }
          }).addTo(map);
          
          // Fit map to the whole state of Paraíba, perfectly encompassing the markers
          map.fitBounds(pbLayer.getBounds(), { padding: [20, 20] });
        });

      // Custom HTML Icons
      const bingoIcon = L.divIcon({
        className: 'custom-div-icon',
        html: "<div style='background-color:#22d3ee;width:14px;height:14px;border-radius:50%;box-shadow: 0 0 15px #22d3ee, 0 0 30px #22d3ee;border:2px solid white;'></div>",
        iconSize: [14, 14],
        iconAnchor: [7, 7]
      });
      
      const cityIcon = L.divIcon({
        className: 'custom-div-icon',
        html: "<div style='background-color:#f59e0b;width:10px;height:10px;border-radius:50%;box-shadow: 0 0 8px #f59e0b;border:2px solid white;'></div>",
        iconSize: [10, 10],
        iconAnchor: [5, 5]
      });

      // Markers with 30-degree rotated tooltips via a safe inner wrapper
      // BINGO: Aguiar, Paraíba
      L.marker([-7.041, -38.268], {icon: bingoIcon})
        .bindTooltip('<div class="custom-tooltip-content">Telescópio BINGO</div>', {permanent: true, direction: 'right', className: 'custom-tooltip-container', offset: [5, -5]})
        .addTo(map);
      // Campina Grande
      L.marker([-7.2307, -35.8811], {icon: cityIcon})
        .bindTooltip('<div class="custom-tooltip-content">Campina Grande</div>', {permanent: true, direction: 'right', className: 'custom-tooltip-container', offset: [5, -5]})
        .addTo(map);
      // João Pessoa
      L.marker([-7.1153, -34.8610], {icon: cityIcon})
        .bindTooltip('<div class="custom-tooltip-content">João Pessoa</div>', {permanent: true, direction: 'right', className: 'custom-tooltip-container', offset: [5, -5]})
        .addTo(map);

      // Custom Ctrl+Scroll logic
      const mapContainer = document.getElementById('paraiba-map-container');
      const ctrlMessage = document.createElement('div');
      ctrlMessage.innerHTML = 'Use <b>Ctrl + Scroll</b> para dar zoom no mapa';
      ctrlMessage.style.cssText = 'position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(15, 23, 42, 0.9); color: #cbd5e1; padding: 12px 24px; border-radius: 8px; z-index: 1000; font-family: Outfit, sans-serif; pointer-events: none; opacity: 0; transition: opacity 0.3s; border: 1px solid rgba(99, 102, 241, 0.3); font-size: 14px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.3);';
      mapContainer.appendChild(ctrlMessage);

      let scrollTimeout;
      mapContainer.addEventListener('wheel', (e) => {
        if (!e.ctrlKey && !e.metaKey) {
          // Show message if ctrl is NOT pressed
          map.scrollWheelZoom.disable();
          ctrlMessage.style.opacity = '1';
          clearTimeout(scrollTimeout);
          scrollTimeout = setTimeout(() => { ctrlMessage.style.opacity = '0'; }, 1500);
        } else {
          // Allow zoom if ctrl IS pressed
          map.scrollWheelZoom.enable();
          ctrlMessage.style.opacity = '0';
          e.preventDefault();
        }
      }, { passive: false });

      // Add custom styles for the map
      const style = document.createElement('style');
      style.innerHTML = `
        .pb-border-glow { filter: drop-shadow(0 0 5px rgba(34, 211, 238, 0.5)); }
        .leaflet-container { background: transparent !important; }
        
        /* Make the default leaflet tooltip box transparent */
        .leaflet-tooltip.custom-tooltip-container {
          background: transparent;
          border: none;
          box-shadow: none;
        }
        .leaflet-tooltip.custom-tooltip-container::before {
          display: none; /* Hide the tooltip arrow */
        }
        
        /* Style the rotated inner content */
        .custom-tooltip-content {
          transform: rotate(-30deg);
          transform-origin: left center;
          background: rgba(255, 255, 255, 0.95);
          color: #0f172a;
          padding: 4px 10px;
          border-radius: 6px;
          box-shadow: 0 2px 5px rgba(0,0,0,0.5);
          font-family: Outfit, sans-serif;
          font-weight: bold;
          white-space: nowrap;
          border: 1px solid rgba(15, 23, 42, 0.1);
        }

        .leaflet-control-zoom a { background: rgba(15, 23, 42, 0.8) !important; color: #cbd5e1 !important; border-color: rgba(99, 102, 241, 0.3) !important; }
        .leaflet-control-zoom a:hover { background: rgba(30, 41, 59, 0.9) !important; color: #38bdf8 !important; }
      `;
      document.head.appendChild(style);
    });
  </script>
</BaseLayout>
