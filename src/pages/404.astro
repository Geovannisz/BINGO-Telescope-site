---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Página não encontrada" nativeI18n pageId="404">
  <div class="relative min-h-screen flex items-center justify-center overflow-hidden bg-cosmic section-bg-image">
    <div class="bg-img" style={`background-image: url('${base}images/backgrounds/WMAP_2012-background.png'); opacity: 0.1;`}></div>
    <div class="bg-overlay" style="background: linear-gradient(180deg, rgba(7,13,31,0.5) 0%, rgba(15,23,42,0.9) 100%);"></div>
    <div class="starfield"></div>

    <div class="relative z-10 mx-auto max-w-2xl px-6 lg:px-8 text-center animate-fade-in-up">
      <p class="text-6xl sm:text-8xl font-black text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-indigo-500 mb-4 tracking-tighter" style="font-family: 'Outfit', sans-serif;">404</p>
      
      <h1 class="text-2xl sm:text-4xl font-bold tracking-tight text-white mb-6" data-t="404.title">
        Perdido no Espaço Profundo
      </h1>
      
      <p class="text-lg leading-8 text-slate-400 mb-10" data-t="404.desc">
        A página que você está procurando não foi encontrada. Pode ter sido movida, excluída ou engolida por um buraco negro.
      </p>

      <div class="flex items-center justify-center gap-x-6">
        <a href={base} class="rounded-full bg-cyan-500/20 border border-cyan-500/50 px-8 py-3 text-sm font-semibold text-cyan-400 shadow-sm hover:bg-cyan-500 hover:text-slate-900 transition-all duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-400" data-t="404.btn">
          Retornar ao Início
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
