---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const latestNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <Hero />

  <!-- Features Section -->
  <section class="py-24 bg-slate-900 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
        <h2 class="text-sm font-semibold text-cyan-400 tracking-wide uppercase mb-3">Visão Geral</h2>
        <div class="section-divider"></div>
        <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-white sm:text-4xl">
          Uma Janela para o Universo Primitivo
        </p>
        <p class="mt-4 max-w-2xl text-lg text-slate-400 mx-auto">
          O telescópio BINGO foi projetado para medir Oscilações Acústicas de Bárions (BAO) no universo em rádio-frequências, ajudando a desvendar os mistérios da Energia Escura.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- BAO Card -->
        <div class="glass-card p-8 text-center animate-on-scroll">
          <div class="w-full h-40 rounded-xl overflow-hidden mb-6 border border-slate-700/30">
            <img src={`${base}images/telescope/BINGO_model_2.jpeg`} alt="Telescópio BINGO - Vista lateral" class="w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Mapeamento BAO</h3>
          <p class="text-slate-400 text-sm">Medindo a distribuição de hidrogênio neutro em 21cm para entender a taxa de expansão do universo e a natureza da Energia Escura.</p>
        </div>

        <!-- FRBs Card -->
        <div class="glass-card p-8 text-center animate-on-scroll">
          <div class="w-full h-40 rounded-xl overflow-hidden mb-6 border border-slate-700/30">
            <img src={`${base}images/horns/horns.png`} alt="Arranjo focal de cornetas do BINGO" class="w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3">FRBs & Transientes</h3>
          <p class="text-slate-400 text-sm">Detectando Fast Radio Bursts e pulsares para investigar fenômenos astrofísicos extremos com o sistema interferométrico BIS.</p>
        </div>

        <!-- ABDUS Card -->
        <div class="glass-card p-8 text-center animate-on-scroll">
          <div class="w-full h-40 rounded-xl overflow-hidden mb-6 border border-slate-700/30 flex items-center justify-center bg-white/5">
            <img src={`${base}images/abdus/Logos-modificados-BINGO-ABDUS.png`} alt="Logo BINGO-ABDUS" class="w-32 h-32 object-contain" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Consórcio BINGO-ABDUS</h3>
          <p class="text-slate-400 text-sm">Operações conjuntas com observatórios globais como FAST e Tianlai, expandindo o alcance até z ~ 2.1.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-16 bg-slate-950 border-y border-slate-800/50 relative overflow-hidden">
    <div class="starfield"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 animate-on-scroll">
        <div class="stat-item">
          <div class="stat-number">~40m</div>
          <div class="stat-label">Diâmetro dos Espelhos</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">28</div>
          <div class="stat-label">Cornetas no Plano Focal</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">10+</div>
          <div class="stat-label">Publicações Científicas</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">7+</div>
          <div class="stat-label">Países Colaboradores</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Subprojects Section -->
  <section class="py-24 bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <h2 class="text-sm font-semibold text-cyan-400 tracking-wide uppercase mb-3">Subprojetos</h2>
        <div class="section-divider"></div>
        <p class="text-3xl font-extrabold text-white sm:text-4xl">Além do Telescópio</p>
        <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">O BINGO é mais que um telescópio — é um ecossistema de ciência, tecnologia e impacto social.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Uirapuru -->
        <a href={`${base}uirapuru`} class="subproject-card group animate-on-scroll">
          <div class="card-image">
            <img src={`${base}images/uirapuru/BINGO-Uirapuru-1024x1024.jpg`} alt="Radiotelescópio BINGO-Uirapuru na UFCG" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent"></div>
          </div>
          <div class="card-content">
            <div class="flex items-center gap-2 mb-2">
              <img src={`${base}images/uirapuru/Logos-modificados-BINGO-Uirapuru.png`} alt="Logo Uirapuru" class="h-8 w-auto" />
            </div>
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">BINGO-Uirapuru</h3>
            <p class="text-slate-400 text-sm">Radiotelescópio protótipo na UFCG, testbed para receptores e futura rede de outriggers para FRBs.</p>
          </div>
        </a>

        <!-- ABDUS -->
        <a href={`${base}abdus`} class="subproject-card group animate-on-scroll">
          <div class="card-image bg-gradient-to-br from-slate-800 to-slate-900 flex items-center justify-center">
            <img src={`${base}images/abdus/Logos-modificados-BINGO-ABDUS.png`} alt="Logo BINGO-ABDUS" class="w-40 h-40 object-contain" />
          </div>
          <div class="card-content">
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">BINGO-ABDUS</h3>
            <p class="text-slate-400 text-sm">Advanced BINGO Dark Universe Studies — expandindo fronteiras em colaboração com ASTRON e Nancy Observatory.</p>
          </div>
        </a>

        <!-- Esperança -->
        <a href={`${base}outreach`} class="subproject-card group animate-on-scroll">
          <div class="card-image bg-gradient-to-br from-amber-900/30 to-slate-900 flex items-center justify-center p-8">
            <img src={`${base}images/outreach/projeto-esperanca-no-espaco-1024x320.png`} alt="Projeto Esperança no Espaço" class="w-full h-auto object-contain" />
          </div>
          <div class="card-content">
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">Esperança no Espaço</h3>
            <p class="text-slate-400 text-sm">Projeto de divulgação científica e inclusão social na Paraíba, levando astronomia a comunidades.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- News Section -->
  <section class="py-24 bg-slate-950 border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-end mb-12 animate-on-scroll">
        <div>
          <h2 class="text-3xl font-extrabold text-white sm:text-4xl">Últimas Atualizações</h2>
          <p class="mt-3 text-lg text-slate-400">Acompanhe os avanços do projeto.</p>
        </div>
        <a href={`${base}news`} class="hidden md:flex items-center text-cyan-400 hover:text-cyan-300 font-medium transition-colors">
          Ver todas
          <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {latestNews.map(post => (
          <div class="animate-on-scroll">
            <NewsCard
              title={post.data.title}
              date={post.data.date.toLocaleDateString('pt-BR')}
              summary={post.data.summary}
              image={post.data.image}
              href={`${base}news/${post.id}`}
            />
          </div>
        ))}
      </div>

      <div class="mt-8 text-center md:hidden">
        <a href={`${base}news`} class="inline-flex items-center text-cyan-400 hover:text-cyan-300 font-medium">
          Ver todas as atualizações
          <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
