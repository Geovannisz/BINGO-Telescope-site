---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const latestNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home" nativeI18n pageId="index">
  <Hero />

  <!-- Features Section — with CMB Planck background -->
  <section class="py-16 sm:py-24 relative overflow-hidden section-bg-image">
    <div class="bg-img" style={`background-image: url('${base}images/backgrounds/cmb_planck-background.png');`}></div>
    <div class="bg-overlay"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
        <p class="section-label" data-t="overview.label">Visão Geral</p>
        <div class="section-divider"></div>
        <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-white sm:text-4xl" style="font-family: 'Outfit', sans-serif;" data-t="overview.title">
          Uma Janela para o Universo Primitivo
        </p>
        <p class="mt-4 max-w-2xl text-lg text-slate-400 mx-auto" data-t="overview.desc">
          O telescópio BINGO foi projetado para medir Oscilações Acústicas de Bárions (BAO) no universo em rádio-frequências, ajudando a desvendar os mistérios da Energia Escura e mapeando a distribuição de hidrogênio neutro em grandes volumes cósmicos.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- BAO Card -->
        <div class="glass-card-glow p-8 text-center animate-on-scroll">
          <div class="w-full h-40 rounded-xl overflow-hidden mb-6 border border-indigo-500/20">
            <img src={`${base}images/backgrounds/baryon-acoustic-oscilations-background.jpg`} alt="Oscilações Acústicas de Bárions" class="w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3" data-t="bao.title">Mapeamento BAO</h3>
          <p class="text-slate-400 text-sm" data-t="bao.desc">Medindo a distribuição de hidrogênio neutro em 21cm para entender a taxa de expansão do universo e a natureza da Energia Escura — fornecendo uma "régua padrão" cósmica independente.</p>
        </div>

        <!-- FRBs Card -->
        <div class="glass-card-glow p-8 text-center animate-on-scroll">
          <div class="w-full h-40 rounded-xl overflow-hidden mb-6 border border-indigo-500/20">
            <img src={`${base}images/uirapuru/uirapuru_horn.png`} alt="Antena Outrigger Uirapuru para Transientes" class="w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3" data-t="frb.title">FRBs &amp; Transientes</h3>
          <p class="text-slate-400 text-sm" data-t="frb.desc">Detectando Fast Radio Bursts — explosões de milissegundos de ondas de rádio vindas de bilhões de anos-luz — e pulsares com o sistema interferométrico BIS.</p>
        </div>

        <!-- ABDUS Card -->
        <div class="glass-card-glow p-8 text-center animate-on-scroll">
          <div class="w-full h-40 rounded-xl overflow-hidden mb-6 border border-indigo-500/20 flex items-center justify-center bg-white/5">
            <img src={`${base}images/abdus/Logos-modificados-BINGO-ABDUS.png`} alt="Logo BINGO-ABDUS" class="w-32 h-32 object-contain" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3" data-t="abdus.title">Consórcio BINGO-ABDUS</h3>
          <p class="text-slate-400 text-sm" data-t="abdus.desc">Operações conjuntas com observatórios globais como FAST e Tianlai, expandindo o alcance até z ~ 2.1 e investigando Buracos Negros Primordiais.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About the Project Section -->
  <section class="py-16 sm:py-24 bg-cosmic relative overflow-hidden">
    <div class="starfield"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="md:flex gap-16 items-center animate-on-scroll">
        <div class="md:w-1/2 mb-10 md:mb-0">
          <div class="rounded-2xl overflow-hidden border border-indigo-500/15 shadow-2xl shadow-cyan-500/5">
            <img src={`${base}images/telescope/BINGO_13-768x432.png`} alt="Render artístico do Telescópio BINGO" class="w-full h-auto" />
          </div>
        </div>
        <div class="md:w-1/2">
          <p class="section-label" data-t="about.label">Sobre o Projeto</p>
          <h2 class="text-3xl font-bold text-white mb-6" style="font-family: 'Outfit', sans-serif;" data-t="about.title">O que é o <span class="gradient-text-cyan">BINGO</span>?</h2>
          <p class="text-slate-300 leading-relaxed mb-4" data-t="about.p1">
            O <strong class="text-white">BINGO</strong> (Baryon Acoustic Oscillations from Integrated Neutral Gas Observations) é um radiotelescópio inovador localizado na Serra do Urubu, em Aguiar, Paraíba. Projetado para realizar o primeiro mapeamento de BAO em frequências de rádio, ele utiliza a técnica de <strong class="text-cyan-400">Intensity Mapping</strong> da linha de 21cm do hidrogênio neutro.
          </p>
          <p class="text-slate-300 leading-relaxed mb-4" data-t="about.p2">
            Com dois espelhos de ~40m em configuração Crossed-Dragone e 28 cornetas corrugadas no plano focal, o BINGO opera entre 980 e 1260 MHz — correspondendo a sinais de HI emitidos quando o universo tinha entre 72% e 88% de sua idade atual.
          </p>
          <p class="text-slate-300 leading-relaxed mb-6" data-t="about.p3">
            É um projeto liderado pelo Brasil (USP, INPE, UFCG) em colaboração internacional com China, Reino Unido, França, Holanda e África do Sul, reunindo mais de 60 pesquisadores.
          </p>
          <a href={`${base}about`} class="inline-flex items-center text-cyan-400 hover:text-cyan-300 font-medium transition-colors">
            <span data-t="about.link">Saiba mais sobre o projeto</span>
            <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Current Phase Section -->
  <section class="py-14 sm:py-20 relative overflow-hidden section-bg-image">
    <div class="bg-img" style={`background-image: url('${base}images/backgrounds/cobe_cmb-background.png'); opacity: 0.06;`}></div>
    <div class="bg-overlay" style="background: linear-gradient(180deg, rgba(7, 13, 31, 0.85) 0%, rgba(15, 23, 42, 0.9) 100%);"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <p class="section-label" data-t="status.label">Status Atual</p>
        <div class="section-divider"></div>
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl" style="font-family: 'Outfit', sans-serif;" data-t="status.title">Fase de Montagem e Comissionamento</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 animate-on-scroll">
        <div class="glass-card-glow p-8">
          <div class="feature-icon mb-4">
            <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2" data-t="status.structure.title">Estrutura Principal</h3>
          <p class="text-slate-400 text-sm" data-t="status.structure.desc">A estrutura metálica dos espelhos, fabricada na China, foi enviada ao Brasil e está sendo montada no site em Aguiar, Paraíba. A casa de comando e infraestrutura de apoio estão concluídas.</p>
        </div>
        <div class="glass-card-glow p-8">
          <div class="feature-icon mb-4">
            <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2" data-t="status.receivers.title">Receptores e Backend</h3>
          <p class="text-slate-400 text-sm" data-t="status.receivers.desc">Receptores de baixo ruído e o backend digital baseado em FPGAs/GPUs estão em fase de integração e testes. O BINGO-Uirapuru na UFCG serve como testbed para validação contínua.</p>
        </div>
        <div class="glass-card-glow p-8">
          <div class="feature-icon mb-4">
            <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2" data-t="status.obs.title">Primeiras Observações</h3>
          <p class="text-slate-400 text-sm" data-t="status.obs.desc">O telescópio está previsto para iniciar as primeiras medições científicas em 2026. A fase de comissionamento incluirá calibração, validação do beam pattern e testes de sensibilidade.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section — with Planck CMB background -->
  <section class="py-12 sm:py-16 relative overflow-hidden section-bg-image border-y border-indigo-500/10">
    <div class="bg-img" style={`background-image: url('${base}images/backgrounds/1567217436969-Planck_CMB_Rectangular_2k-background.jpg'); opacity: 0.1;`}></div>
    <div class="bg-overlay" style="background: linear-gradient(180deg, rgba(7, 13, 31, 0.8) 0%, rgba(7, 13, 31, 0.9) 100%);"></div>
    <div class="starfield"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-4 gap-4 sm:gap-8 animate-on-scroll">
        <div class="stat-item">
          <div class="stat-number">~40m</div>
          <div class="stat-label" data-t="stats.mirrors">Diâmetro dos Espelhos</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">28</div>
          <div class="stat-label" data-t="stats.horns">Cornetas no Plano Focal</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">10+</div>
          <div class="stat-label" data-t="stats.publications">Publicações Científicas</div>
        </div>
        <div class="stat-item flex flex-col items-center">
          <div class="flex justify-center gap-1 sm:gap-1.5 mb-2 flex-wrap">
            <img src="https://flagcdn.com/br.svg" alt="Brasil" class="h-5 sm:h-6 w-auto rounded shadow" title="Brasil" />
            <img src="https://flagcdn.com/cn.svg" alt="China" class="h-5 sm:h-6 w-auto rounded shadow" title="China" />
            <img src="https://flagcdn.com/in.svg" alt="Índia" class="h-5 sm:h-6 w-auto rounded shadow" title="Índia" />
            <img src="https://flagcdn.com/gb.svg" alt="Reino Unido" class="h-5 sm:h-6 w-auto rounded shadow" title="Reino Unido" />
            <img src="https://flagcdn.com/fr.svg" alt="França" class="h-5 sm:h-6 w-auto rounded shadow" title="França" />
            <img src="https://flagcdn.com/nl.svg" alt="Holanda" class="h-5 sm:h-6 w-auto rounded shadow" title="Holanda" />
            <img src="https://flagcdn.com/za.svg" alt="África do Sul" class="h-5 sm:h-6 w-auto rounded shadow" title="África do Sul" />
          </div>
          <div class="stat-number text-xl sm:text-2xl mt-1">7+</div>
          <div class="stat-label" data-t="stats.countries">Países Colaboradores</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Extensions Section -->
  <section class="py-16 sm:py-24 bg-cosmic-alt">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <p class="section-label" data-t="ext.label">Extensões</p>
        <div class="section-divider"></div>
        <p class="text-3xl font-extrabold text-white sm:text-4xl" style="font-family: 'Outfit', sans-serif;" data-t="ext.title">Além do Telescópio</p>
        <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto" data-t="ext.desc">O BINGO é mais que um telescópio — é um ecossistema de ciência, tecnologia e impacto social que se estende por múltiplas frentes de pesquisa e ação comunitária.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Uirapuru -->
        <a href={`${base}uirapuru`} class="subproject-card group animate-on-scroll">
          <div class="card-image">
            <img src={`${base}images/uirapuru/BINGO-Uirapuru-1024x1024.jpg`} alt="Radiotelescópio BINGO-Uirapuru na UFCG" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#070d1f] via-[#070d1f]/20 to-transparent"></div>
          </div>
          <div class="card-content">
            <div class="flex items-center gap-2 mb-2">
              <img src={`${base}images/uirapuru/Logos-modificados-BINGO-Uirapuru.png`} alt="Logo Uirapuru" class="h-8 w-auto" />
            </div>
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">BINGO-Uirapuru</h3>
            <p class="text-slate-400 text-sm" data-t="ext.uirapuru.desc">Radiotelescópio protótipo na UFCG, testbed para receptores e futura rede de outriggers para detecção e localização de FRBs.</p>
          </div>
        </a>

        <!-- ABDUS -->
        <a href={`${base}abdus`} class="subproject-card group animate-on-scroll">
          <div class="card-image bg-gradient-to-br from-indigo-900/40 to-[#070d1f] flex items-center justify-center p-8">
            <img src={`${base}images/abdus/Logos-modificados-BINGO-ABDUS.png`} alt="Logo BINGO-ABDUS" class="w-full h-full !object-contain" />
          </div>
          <div class="card-content">
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">BINGO-ABDUS</h3>
            <p class="text-slate-400 text-sm" data-t="ext.abdus.desc">Advanced BINGO Dark Universe Studies — expandindo fronteiras em colaboração com ASTRON e Observatório de Nançay, alcançando z ~ 2.1.</p>
          </div>
        </a>

        <!-- Esperança -->
        <a href={`${base}outreach`} class="subproject-card group animate-on-scroll">
          <div class="card-image bg-gradient-to-br from-amber-900/20 to-[#070d1f] flex items-center justify-center p-8">
            <img src={`${base}images/outreach/projeto-esperanca-no-espaco-1024x320.png`} alt="Projeto Esperança no Espaço" class="w-full h-full !object-contain" />
          </div>
          <div class="card-content">
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-amber-400 transition-colors" data-t="ext.esperanca.title">Esperança no Espaço</h3>
            <p class="text-slate-400 text-sm" data-t="ext.esperanca.desc">Projeto de divulgação científica e inclusão social na Paraíba — construção de telescópios com materiais reciclados e popularização da astronomia.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- News Section -->
  <section class="py-16 sm:py-24 bg-cosmic border-t border-indigo-500/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-end mb-12 animate-on-scroll">
        <div>
          <h2 class="text-3xl font-extrabold text-white sm:text-4xl" style="font-family: 'Outfit', sans-serif;" data-t="news.title">Últimas Atualizações</h2>
          <p class="mt-3 text-lg text-slate-400" data-t="news.subtitle">Acompanhe os avanços do projeto.</p>
        </div>
        <a href={`${base}news`} class="hidden md:flex items-center text-cyan-400 hover:text-cyan-300 font-medium transition-colors">
          <span data-t="news.viewall">Ver todas</span>
          <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {latestNews.map(post => (
          <div class="animate-on-scroll">
            <NewsCard
              title={post.data.title}
              date={post.data.date.toLocaleDateString('pt-BR')}
              summary={post.data.summary}
              image={post.data.image}
              href={`${base}news/${post.id}`}
            />
          </div>
        ))}
      </div>

      <div class="mt-8 text-center md:hidden">
        <a href={`${base}news`} class="inline-flex items-center text-cyan-400 hover:text-cyan-300 font-medium">
          <span data-t="news.viewall.mobile">Ver todas as atualizações</span>
          <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
