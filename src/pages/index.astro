---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const latestNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
---

<BaseLayout title="Home">
  <Hero />

  <section class="py-24 bg-slate-900 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-sm font-semibold text-cyan-400 tracking-wide uppercase mb-3">Visão Geral</h2>
        <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-white sm:text-4xl">
          Uma Janela para o Universo Primitivo
        </p>
        <p class="mt-4 max-w-2xl text-xl text-slate-400 mx-auto">
          O telescópio BINGO foi projetado para medir Oscilações Acústicas de Bárions (BAO) no universo em rádio-frequências, ajudando a desvendar os mistérios da Energia Escura e estudando fenômenos astrofísicos fantásticos.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-slate-800/30 border border-slate-700/50 rounded-2xl p-8 text-center hover:bg-slate-800/50 transition-colors">
          <div class="w-16 h-16 mx-auto bg-cyan-500/10 rounded-2xl flex items-center justify-center mb-6 border border-cyan-500/20">
             <svg class="w-8 h-8 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Mapeamento BAO</h3>
          <p class="text-slate-400 text-sm">Medindo a distribuição de hidrogênio neutro para entender a taxa de expansão do universo.</p>
        </div>
        <div class="bg-slate-800/30 border border-slate-700/50 rounded-2xl p-8 text-center hover:bg-slate-800/50 transition-colors">
          <div class="w-16 h-16 mx-auto bg-cyan-500/10 rounded-2xl flex items-center justify-center mb-6 border border-cyan-500/20">
            <svg class="w-8 h-8 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">FRBs & Transientes</h3>
          <p class="text-slate-400 text-sm">Detectando Fast Radio Bursts (Rajadas Rápidas de Rádio) e pulsares para investigar fenômenos astrofísicos extremos.</p>
        </div>
        <div class="bg-slate-800/30 border border-slate-700/50 rounded-2xl p-8 text-center hover:bg-slate-800/50 transition-colors">
          <div class="w-16 h-16 mx-auto bg-cyan-500/10 rounded-2xl flex items-center justify-center mb-6 border border-cyan-500/20">
            <svg class="w-8 h-8 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Consórcio BINGO-ABDUS</h3>
          <p class="text-slate-400 text-sm">Operações conjuntas com observatórios globais como FAST e Tianlai para observações inéditas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Seção de Notícias com Grid moderno -->
  <section class="py-24 bg-slate-950 border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-end mb-12">
        <div>
          <h2 class="text-3xl font-extrabold text-white sm:text-4xl">Últimas Atualizações</h2>
          <p class="mt-3 text-xl text-slate-400">Acompanhe os avanços do projeto e as mídias.</p>
        </div>
        <a href="/BINGO-Telescope-site/news" class="hidden md:flex items-center text-cyan-400 hover:text-cyan-300 font-medium">
          Ver todas
          <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {latestNews.map(post => (
          <NewsCard
            title={post.data.title}
            date={post.data.date.toLocaleDateString('pt-BR')}
            summary={post.data.summary}
            image={post.data.image}
            href={`/BINGO-Telescope-site/news/${post.id}`}
          />
        ))}
      </div>

      <div class="mt-8 text-center md:hidden">
         <a href="/BINGO-Telescope-site/news" class="inline-flex items-center text-cyan-400 hover:text-cyan-300 font-medium">
          Ver todas as atualizações
          <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
