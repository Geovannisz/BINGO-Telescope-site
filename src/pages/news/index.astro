---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Notícias e Blog">
  <div class="py-24 sm:py-32 bg-slate-950 min-h-screen">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Notícias e Atualizações</h2>
        <p class="mt-4 text-lg text-slate-400">
          Acompanhe os últimos desenvolvimentos, marcos e histórias do projeto BINGO.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedNews.map(post => (
          <NewsCard
            title={post.data.title}
            date={post.data.date.toLocaleDateString('pt-BR')}
            summary={post.data.summary}
            image={post.data.image}
            href={`/BINGO-Telescope-site/news/${post.id}`}
          />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
