---
import BaseLayout from '../layouts/BaseLayout.astro';
import TeamMember from '../components/TeamMember.astro';
import { getCollection } from 'astro:content';

const allTeam = await getCollection('team');
const sortedTeam = allTeam.sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout title="Equipe">
  <div class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Nossa Equipe</h2>
        <p class="mt-4 text-lg text-slate-400">
          A colaboração internacional por trás do telescópio BINGO.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
        {sortedTeam.map((member) => (
          <TeamMember
            name={member.data.name}
            role={member.data.role}
            institution={member.data.institution}
            photo={member.data.photo}
          />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
