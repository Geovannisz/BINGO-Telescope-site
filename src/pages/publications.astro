---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPubs = await getCollection('publications');
const sortedPubs = allPubs.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Publicações">
  <div class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Publicações Científicas</h2>
        <p class="mt-4 text-lg text-slate-400">
          Artigos, teses e relatórios técnicos produzidos pelo consórcio.
        </p>
      </div>

      <div class="space-y-6 max-w-4xl mx-auto">
        {sortedPubs.map((pub) => (
          <div class="bg-slate-800/40 rounded-xl border border-slate-700/50 p-6 flex flex-col sm:flex-row gap-6 justify-between items-start transition-all hover:bg-slate-800">
            <div>
              <h3 class="text-xl font-bold text-white mb-2">{pub.data.title}</h3>
              <p class="text-cyan-400 text-sm mb-2">{pub.data.authors}</p>
              <div class="text-slate-400 text-sm flex gap-4 mb-3">
                <span>{pub.data.date.getFullYear()}</span>
              </div>
              {pub.data.summary && <p class="text-slate-300 text-sm leading-relaxed">{pub.data.summary}</p>}
            </div>
            {pub.data.link && (
              <a href={pub.data.link} target="_blank" rel="noopener noreferrer" class="shrink-0 inline-flex items-center px-4 py-2 border border-slate-600 text-sm font-medium rounded-md text-white bg-slate-700 hover:bg-slate-600 focus:outline-none transition-colors">
                Acessar PDF / DOI
                <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
