---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPubs = await getCollection('publications');
const allTeam = await getCollection('team');

const teamPubs: any[] = [];
allTeam.forEach(member => {
  if (member.data.publications && member.data.publications.length > 0) {
    member.data.publications.forEach((pub: any, index: number) => {
      if (pub.title) {
        teamPubs.push({
          id: `team-${member.id}-${index}`,
          collection: 'publications',
          data: {
            title: pub.title,
            authors: pub.authors || member.data.name,
            date: pub.date ? new Date(pub.date) : new Date(),
            link: pub.link,
            summary: pub.summary,
            journal: pub.journal,
            volume: pub.volume,
            issue: pub.issue,
            pages: pub.pages,
            doi: pub.doi,
            category: pub.category,
            _source: 'team',
            _memberName: member.data.name,
          }
        });
      }
    });
  }
});

const combinedPubs = [...allPubs.map(p => ({
  ...p,
  data: { ...p.data, _source: 'collection' }
})), ...teamPubs];

// Deduplicate publications by DOI, URL, or Title
function getDoi(pub: any): string {
  const doi = pub.data.doi || '';
  if (doi) return doi.toLowerCase().trim();
  const link = pub.data.link || '';
  const m = link.match(/10\.\d{4,9}\/[-._;()/:A-Za-z0-9]+/);
  return m ? m[0].toLowerCase().trim() : '';
}

function getCleanUrl(pub: any): string {
  const link = pub.data.link || '';
  return link.toLowerCase().replace(/^https?:\/\/(www\.)?/, '').replace(/\/$/, '').trim();
}

function getNormTitle(pub: any): string {
  const t = pub.data.title || '';
  return t.toLowerCase().trim().replace(/[^\w\s]/g, '').replace(/\s+/g, ' ');
}

const seenDois = new Set<string>();
const seenUrls = new Set<string>();
const seenTitles = new Set<string>();
const uniquePubs: typeof combinedPubs = [];

for (const pub of combinedPubs) {
  const doi = getDoi(pub);
  const url = getCleanUrl(pub);
  const title = getNormTitle(pub);

  if (!title && !doi && !url) continue;

  const isSeen = (doi && seenDois.has(doi)) || 
                 (url && seenUrls.has(url)) || 
                 (title && seenTitles.has(title));

  if (!isSeen) {
    if (doi) seenDois.add(doi);
    if (url) seenUrls.add(url);
    if (title) seenTitles.add(title);
    uniquePubs.push(pub);
  }
}

const sortedPubs = uniquePubs.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Extract unique years and journals for filters
const years = [...new Set(sortedPubs.map(p => new Date(p.data.date).getFullYear()))].sort((a, b) => b - a);
const journals = [...new Set(sortedPubs.filter(p => p.data.journal).map(p => p.data.journal!))].sort();

// Determine category for each pub (auto-detect if not set)
function getCategory(pub: any): string {
  if (pub.data.category) return pub.data.category;
  if (pub.data.title.includes('BINGO Project') || pub.data.title.includes('BINGO project')) return 'Série Principal';
  if (pub.data.title.includes('ABDUS') || pub.data.title.includes('abdus')) return 'ABDUS';
  return '';
}

// Count stats
const peerReviewedCount = sortedPubs.filter(p => p.data.link?.includes('doi.org')).length;
const uniqueJournals = journals.length;
const yearSpan = years.length > 0 ? `${years[years.length - 1]}-${years[0]}` : '';
---

<BaseLayout 
  title="Publicações"
  description="Artigos científicos, teses e relatórios técnicos produzidos pelo consórcio BINGO, com publicações focadas em rádio-astronomia e cosmologia na Astronomy & Astrophysics (A&A)."
>
  <!-- ===== HERO SECTION ===== -->
  <div class="relative py-16 sm:py-24 overflow-hidden section-bg-image" style="min-height: 35vh;">
    <div class="starfield"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-6 lg:px-8">
      <div class="max-w-3xl animate-fade-in-up">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 mb-6">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          Produção Científica
        </div>
        <h1 class="text-4xl font-black tracking-tight text-white sm:text-6xl">
          Publicações <span class="gradient-text-cyan">Científicas</span>
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-300 max-w-2xl">
          Artigos, teses e relatórios técnicos produzidos pelo consórcio BINGO.
        </p>
      </div>

      <!-- Stats bar -->
      <div class="mt-10 grid grid-cols-2 sm:grid-cols-[1fr_1fr_1fr_1.15fr] gap-4 max-w-2xl animate-fade-in-up notranslate" translate="no" style="animation-delay: 0.3s;">
        <div class="glass-card p-4 text-center">
          <div class="text-2xl sm:text-3xl font-bold gradient-text-cyan">{sortedPubs.length}</div>
          <div class="text-xs text-slate-400 mt-1 uppercase tracking-wider" data-pub-t="ui.publications">Publicações</div>
        </div>
        <div class="glass-card p-4 text-center">
          <div class="text-2xl sm:text-3xl font-bold gradient-text-cyan">{peerReviewedCount}</div>
          <div class="text-xs text-slate-400 mt-1 uppercase tracking-wider" data-pub-t="ui.peer_reviewed">Peer-reviewed</div>
        </div>
        <div class="glass-card p-4 text-center">
          <div class="text-2xl sm:text-3xl font-bold gradient-text-cyan">{uniqueJournals}</div>
          <div class="text-xs text-slate-400 mt-1 uppercase tracking-wider" data-pub-t="ui.periodicos">Periódicos</div>
        </div>
        <div class="glass-card p-4 px-2 sm:px-3 text-center">
          <div class="text-xl sm:text-2xl font-bold gradient-text-cyan whitespace-nowrap px-1">{yearSpan}</div>
          <div class="text-xs text-slate-400 mt-1 uppercase tracking-wider" data-pub-t="ui.periodo">Período</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== MAIN CONTENT ===== -->
  <div class="pb-24 pt-10 bg-cosmic">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">

      <!-- ===== SEARCH + CONTROLS BAR ===== -->
      <div class="pub-controls-container mb-8 animate-on-scroll notranslate" translate="no">
        <!-- Search Bar -->
        <div class="pub-search-wrapper">
          <div class="pub-search-icon">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <input 
            type="text" 
            id="pub-search-input" 
            placeholder="Buscar por título, autores, resumo ou periódico..." 
            data-pub-placeholder="ui.search_placeholder"
            class="pub-search-input"
            autocomplete="off"
          />
          <button id="pub-search-clear" class="pub-search-clear hidden" aria-label="Limpar busca">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <!-- Filter and Sort Controls Row -->
        <div class="pub-filter-row">
          <!-- Filters -->
          <div class="pub-filters-group">
            <!-- Year filter -->
            <div class="pub-filter-select-wrapper">
              <select id="pub-filter-year" class="pub-filter-select">
                <option value="" data-pub-t="ui.all_years">Todos os anos</option>
                {years.map(y => <option value={y}>{y}</option>)}
              </select>
              <svg class="pub-filter-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>

            <!-- Journal filter -->
            <div class="pub-filter-select-wrapper">
              <select id="pub-filter-journal" class="pub-filter-select">
                <option value="" data-pub-t="ui.all_journals">Todos os periódicos</option>
                {journals.map(j => <option value={j}>{j}</option>)}
              </select>
              <svg class="pub-filter-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>

            <!-- Category filter -->
            <div class="pub-filter-select-wrapper">
              <select id="pub-filter-category" class="pub-filter-select">
                <option value="" data-pub-t="ui.all_categories">Todas as categorias</option>
                <option value="Série Principal" data-pub-t="category.Série Principal">Série Principal</option>
                <option value="ABDUS" data-pub-t="category.ABDUS">ABDUS</option>
                <option value="Colaboração" data-pub-t="category.Colaboração">Colaboração</option>
                <option value="Tese" data-pub-t="category.Tese">Tese</option>
                <option value="Outro" data-pub-t="category.Outro">Outro</option>
              </select>
              <svg class="pub-filter-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>

            </div>

          <!-- Sort -->
          <div class="pub-sort-group">
            <div class="pub-filter-select-wrapper">
              <select id="pub-sort" class="pub-filter-select pub-sort-select">
                <option value="date-desc" data-pub-t="ui.sort_recent">Mais recente</option>
                <option value="date-asc" data-pub-t="ui.sort_oldest">Mais antigo</option>
                <option value="title-asc" data-pub-t="ui.sort_title_asc">A → Z (título)</option>
                <option value="title-desc" data-pub-t="ui.sort_title_desc">Z → A (título)</option>
              </select>
              <svg class="pub-filter-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </div>
        </div>

        <!-- Active filters & results count -->
        <div class="pub-status-bar">
          <div id="pub-results-count" class="pub-results-count">
            <span class="pub-results-number">{sortedPubs.length}</span> <span data-pub-t="ui.results_suffix">publicações encontradas</span>
          </div>
          <button id="pub-clear-filters" class="pub-clear-filters hidden">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            <span data-pub-t="ui.clear_filters">Limpar filtros</span>
          </button>
        </div>
      </div>

      <!-- ===== PUBLICATIONS LIST ===== -->
      <div id="pub-list" class="space-y-4">
        {sortedPubs.map((pub, i) => {
          const category = getCategory(pub);
          const pubYear = new Date(pub.data.date).getFullYear();
          const pubJournal = pub.data.journal || '';
          const pubSource = pub.data._source || 'collection';
          const hasSummary = !!pub.data.summary;

          return (
            <div 
              class="pub-card glass-card animate-on-scroll"
              data-title={pub.data.title.toLowerCase()}
              data-authors={(pub.data.authors || '').toLowerCase()}
              data-summary={(pub.data.summary || '').toLowerCase()}
              data-journal={pubJournal.toLowerCase()}
              data-year={pubYear}
              data-category={category}
              data-source={pubSource}
              data-date={new Date(pub.data.date).valueOf()}
            >
              <div class="pub-card-main">
                <!-- Number -->
                <div class="pub-number notranslate" translate="no">
                  <span class="pub-number-text">{String(i + 1).padStart(2, '0')}</span>
                </div>
                
                <!-- Content -->
                <div class="pub-card-content">
                  <!-- Tags Row -->
                  <div class="pub-tags-row">
                    {category === 'Série Principal' && (
                      <span class="pub-tag pub-tag-primary notranslate" translate="no">
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                        <span data-pub-t="category.Série Principal">Série Principal</span>
                      </span>
                    )}
                    {category === 'ABDUS' && (
                      <span class="pub-tag pub-tag-abdus notranslate" translate="no" data-pub-t="category.ABDUS">BINGO-ABDUS</span>
                    )}
                    {category === 'Colaboração' && (
                      <span class="pub-tag pub-tag-collab notranslate" translate="no" data-pub-t="category.Colaboração">Colaboração</span>
                    )}
                    {pub.data.link?.includes('doi.org') && (
                      <span class="pub-tag pub-tag-peer notranslate" translate="no">
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <span data-pub-t="ui.peer_reviewed">Peer-reviewed</span>
                      </span>
                    )}
                    {pub.data.link?.includes('arxiv') && (
                      <span class="pub-tag pub-tag-arxiv notranslate" translate="no">arXiv</span>
                    )}
                    {pubSource === 'team' && (
                      <span class="pub-tag pub-tag-team notranslate" translate="no">
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        <span data-pub-t="source.badge.team">Equipe</span>
                      </span>
                    )}
                    <span class="pub-year-badge notranslate" translate="no">{pubYear}</span>
                  </div>

                  <!-- Title -->
                  <h3 class="pub-title">{pub.data.title}</h3>

                  <!-- Authors -->
                  <p class="pub-authors notranslate" translate="no">{pub.data.authors}</p>

                  <!-- Journal info -->
                  {pub.data.journal && (
                    <p class="pub-journal notranslate" translate="no">
                      <svg class="w-3.5 h-3.5 inline-block mr-1 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
                      {pub.data.journal}
                      {pub.data.volume && <span>, Vol. {pub.data.volume}</span>}
                      {pub.data.issue && <span>, No. {pub.data.issue}</span>}
                      {pub.data.pages && <span>, pp. {pub.data.pages}</span>}
                    </p>
                  )}

                  <!-- Summary (hover reveal) -->
                  {hasSummary && (
                    <div class="pub-summary-container">
                      <div class="pub-summary-label notranslate" translate="no">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <span data-pub-t="ui.hover_summary">Passe o mouse para ver o resumo</span>
                      </div>
                      <div class="pub-summary-content">
                        <p>{pub.data.summary}</p>
                      </div>
                    </div>
                  )}
                </div>

                <!-- Action -->
                <div class="pub-card-action notranslate" translate="no">
                  {pub.data.link ? (
                    <a href={pub.data.link} target="_blank" rel="noopener noreferrer" class="pub-access-btn" aria-label={`Acessar: ${pub.data.title}`}>
                      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                      <span class="pub-access-label" data-pub-t="ui.access">Acessar</span>
                    </a>
                  ) : (
                    <span class="pub-no-link">
                      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L3 3m6.878 6.878L21 21"/></svg>
                    </span>
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <!-- ===== EMPTY STATE ===== -->
      <div id="pub-empty" class="pub-empty hidden notranslate" translate="no">
        <div class="pub-empty-icon">
          <svg width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-300 mt-4" data-pub-t="ui.no_pubs">Nenhuma publicação encontrada</h3>
        <p class="text-sm text-slate-500 mt-2" data-pub-t="ui.adjust_filters">Tente ajustar os filtros ou o termo de busca.</p>
      </div>

      <!-- ===== PAGINATION ===== -->
      <div 
        id="pub-pagination" 
        class="pub-pagination mt-10 animate-on-scroll notranslate" 
        translate="no"
        data-pagination-of-pt="de"
        data-pagination-of-en="of"
        data-pagination-of-zh="/"
      >
        <!-- Dynamically rendered by JS -->
      </div>

    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const ITEMS_PER_PAGE = 15;
      let currentPage = 1;

      const searchInput = document.getElementById('pub-search-input') as HTMLInputElement;
      const searchClear = document.getElementById('pub-search-clear')!;
      const filterYear = document.getElementById('pub-filter-year') as HTMLSelectElement;
      const filterJournal = document.getElementById('pub-filter-journal') as HTMLSelectElement;
      const filterCategory = document.getElementById('pub-filter-category') as HTMLSelectElement;
      const sortSelect = document.getElementById('pub-sort') as HTMLSelectElement;
      const clearFilters = document.getElementById('pub-clear-filters')!;
      const resultsCount = document.getElementById('pub-results-count')!;
      const pubList = document.getElementById('pub-list')!;
      const pubEmpty = document.getElementById('pub-empty')!;
      const pagination = document.getElementById('pub-pagination')!;

      const allCards = Array.from(pubList.querySelectorAll('.pub-card')) as HTMLElement[];

      // ── SEARCH ──
      let debounceTimer: ReturnType<typeof setTimeout>;
      searchInput.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
          currentPage = 1;
          applyFilters();
        }, 300);
        searchClear.classList.toggle('hidden', !searchInput.value);
      });

      searchClear.addEventListener('click', () => {
        searchInput.value = '';
        searchClear.classList.add('hidden');
        currentPage = 1;
        applyFilters();
        searchInput.focus();
      });

      // ── FILTERS ──
      [filterYear, filterJournal, filterCategory].forEach(el => {
        el.addEventListener('change', () => {
          currentPage = 1;
          applyFilters();
        });
      });

      // ── SORT ──
      sortSelect.addEventListener('change', () => {
        currentPage = 1;
        applyFilters();
      });

      // ── CLEAR ALL ──
      clearFilters.addEventListener('click', () => {
        searchInput.value = '';
        searchClear.classList.add('hidden');
        filterYear.value = '';
        filterJournal.value = '';
        filterCategory.value = '';
        sortSelect.value = 'date-desc';
        currentPage = 1;
        applyFilters();
      });

      function getFilteredCards(): HTMLElement[] {
        const query = searchInput.value.toLowerCase().trim();
        const year = filterYear.value;
        const journal = filterJournal.value.toLowerCase();
        const category = filterCategory.value;

        let filtered = allCards.filter(card => {
          // Search
          if (query) {
            const title = card.dataset.title || '';
            const authors = card.dataset.authors || '';
            const summary = card.dataset.summary || '';
            const journalData = card.dataset.journal || '';
            const match = title.includes(query) || authors.includes(query) || summary.includes(query) || journalData.includes(query);
            if (!match) return false;
          }

          // Year filter
          if (year && card.dataset.year !== year) return false;

          // Journal filter
          if (journal && (card.dataset.journal || '').toLowerCase() !== journal) return false;

          // Category filter
          if (category && card.dataset.category !== category) return false;

          return true;
        });

        // Sort
        const sortValue = sortSelect.value;
        filtered.sort((a, b) => {
          switch (sortValue) {
            case 'date-asc':
              return Number(a.dataset.date) - Number(b.dataset.date);
            case 'title-asc':
              return (a.dataset.title || '').localeCompare(b.dataset.title || '', 'pt');
            case 'title-desc':
              return (b.dataset.title || '').localeCompare(a.dataset.title || '', 'pt');
            default: // date-desc
              return Number(b.dataset.date) - Number(a.dataset.date);
          }
        });

        return filtered;
      }

      function applyFilters() {
        const filtered = getFilteredCards();
        const totalPages = Math.max(1, Math.ceil(filtered.length / ITEMS_PER_PAGE));
        if (currentPage > totalPages) currentPage = totalPages;

        // Hide all cards
        allCards.forEach(c => {
          c.style.display = 'none';
          c.classList.remove('is-visible');
        });

        // Show cards for current page
        const start = (currentPage - 1) * ITEMS_PER_PAGE;
        const end = start + ITEMS_PER_PAGE;
        const pageCards = filtered.slice(start, end);

        // Re-number visible cards
        pageCards.forEach((card, idx) => {
          card.style.display = '';
          // Stagger animation
          setTimeout(() => card.classList.add('is-visible'), idx * 50);
          // Update number
          const numEl = card.querySelector('.pub-number-text');
          if (numEl) numEl.textContent = String(start + idx + 1).padStart(2, '0');
        });

        // Update results count
        const countEl = resultsCount.querySelector('.pub-results-number');
        if (countEl) countEl.textContent = String(filtered.length);

        // Show/hide empty state
        if (filtered.length === 0) {
          pubEmpty.classList.remove('hidden');
          pubList.style.display = 'none';
        } else {
          pubEmpty.classList.add('hidden');
          pubList.style.display = '';
        }

        // Show/hide clear filters
        const hasFilters = searchInput.value || filterYear.value || filterJournal.value || filterCategory.value || sortSelect.value !== 'date-desc';
        clearFilters.classList.toggle('hidden', !hasFilters);

        // Render pagination
        renderPagination(filtered.length, totalPages);
      }

      function renderPagination(total: number, totalPages: number) {
        if (totalPages <= 1) {
          pagination.innerHTML = '';
          return;
        }

        let html = '<div class="pub-pagination-inner">';

        // Previous
        html += `<button class="pub-page-btn ${currentPage === 1 ? 'disabled' : ''}" data-page="${currentPage - 1}" ${currentPage === 1 ? 'disabled' : ''}>
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </button>`;

        // Page numbers
        const maxVisible = 7;
        let startP = Math.max(1, currentPage - 3);
        let endP = Math.min(totalPages, startP + maxVisible - 1);
        if (endP - startP < maxVisible - 1) startP = Math.max(1, endP - maxVisible + 1);

        if (startP > 1) {
          html += `<button class="pub-page-btn" data-page="1">1</button>`;
          if (startP > 2) html += `<span class="pub-page-dots">…</span>`;
        }

        for (let i = startP; i <= endP; i++) {
          html += `<button class="pub-page-btn ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
        }

        if (endP < totalPages) {
          if (endP < totalPages - 1) html += `<span class="pub-page-dots">…</span>`;
          html += `<button class="pub-page-btn" data-page="${totalPages}">${totalPages}</button>`;
        }

        // Next
        html += `<button class="pub-page-btn ${currentPage === totalPages ? 'disabled' : ''}" data-page="${currentPage + 1}" ${currentPage === totalPages ? 'disabled' : ''}>
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </button>`;

        const rawLang = localStorage.getItem('bingo-lang') || 'en';
        const langCode = rawLang === 'zh-CN' ? 'zh' : rawLang;
        const deText = pagination.getAttribute(`data-pagination-of-${langCode}`) || 'de';

        html += `<span class="pub-page-info">${((currentPage - 1) * ITEMS_PER_PAGE) + 1}–${Math.min(currentPage * ITEMS_PER_PAGE, total)} ${deText} ${total}</span>`;
        html += '</div>';

        pagination.innerHTML = html;

        // Bind page buttons
        pagination.querySelectorAll('.pub-page-btn:not(.disabled)').forEach(btn => {
          btn.addEventListener('click', () => {
            currentPage = Number((btn as HTMLElement).dataset.page);
            applyFilters();
            // Scroll to top of list
            pubList.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
        });
      }

      // ── KEYBOARD SHORTCUT ──
      document.addEventListener('keydown', (e) => {
        if (e.key === '/' && !['INPUT', 'TEXTAREA', 'SELECT'].includes((e.target as HTMLElement).tagName)) {
          e.preventDefault();
          searchInput.focus();
        }
        if (e.key === 'Escape' && document.activeElement === searchInput) {
          searchInput.blur();
        }
      });

      // Initial render
      applyFilters();
    });
  </script>
</BaseLayout>
