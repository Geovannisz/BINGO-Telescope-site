---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPubs = await getCollection('publications');
const allTeam = await getCollection('team');

const teamPubs: any[] = [];
allTeam.forEach(member => {
  if (member.data.publications && member.data.publications.length > 0) {
    member.data.publications.forEach((pub: any, index: number) => {
      if (pub.title) {
        teamPubs.push({
          id: `team-${member.id}-${index}`,
          collection: 'publications',
          data: {
            title: pub.title,
            authors: pub.authors || member.data.name,
            date: pub.date ? new Date(pub.date) : new Date(),
            link: pub.link,
            summary: pub.summary
          }
        });
      }
    });
  }
});

const combinedPubs = [...allPubs, ...teamPubs];
const sortedPubs = combinedPubs.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout 
  title="Publicações"
  description="Artigos científicos, teses e relatórios técnicos produzidos pelo consórcio BINGO, com publicações focadas em rádio-astronomia e cosmologia na Astronomy & Astrophysics (A&A)."
>
  <div class="relative py-16 sm:py-20 overflow-hidden section-bg-image" style="min-height: 30vh;">
    <div class="starfield"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-3xl animate-fade-in-up">
        <h1 class="text-4xl font-black tracking-tight text-white sm:text-6xl">Publicações <span class="text-cyan-400">Científicas</span></h1>
        <p class="mt-6 text-lg leading-8 text-slate-300">
          Artigos, teses e relatórios técnicos produzidos pelo consórcio BINGO, publicados principalmente na Astronomy & Astrophysics (A&A).
        </p>
      </div>
    </div>
  </div>

  <div class="pb-24 pt-10 bg-cosmic">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <!-- Publication count -->
      <div class="mb-8 animate-on-scroll">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-cyan-500/10 text-cyan-400 border border-cyan-500/20">
          {sortedPubs.length} publicações
        </span>
      </div>

      <div class="space-y-6">
        {sortedPubs.map((pub, i) => (
          <div class={`glass-card p-6 flex flex-col sm:flex-row gap-6 justify-between items-start animate-on-scroll`}>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-2 flex-wrap">
                {pub.data.title.includes('BINGO Project') && (
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-cyan-500/10 text-cyan-400 border border-cyan-500/20">
                    Série Principal
                  </span>
                )}
                {pub.data.title.includes('ABDUS') && (
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-amber-500/10 text-amber-400 border border-amber-500/20">
                    BINGO-ABDUS
                  </span>
                )}
                <span class="text-slate-500 text-xs">{pub.data.date.getFullYear()}</span>
              </div>
              <h3 class="text-lg font-bold text-white mb-2 leading-snug">{pub.data.title}</h3>
              <p class="text-cyan-400/80 text-sm mb-2">{pub.data.authors}</p>
              {pub.data.summary && <p class="text-slate-400 text-sm leading-relaxed">{pub.data.summary}</p>}
              {pub.data.link && (
                <div class="mt-3 flex gap-3 flex-wrap">
                  {pub.data.link.includes('doi.org') && (
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-500/10 text-green-400 border border-green-500/20">
                      <svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      Peer-reviewed
                    </span>
                  )}
                  {pub.data.link.includes('arxiv') && (
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-orange-500/10 text-orange-400 border border-orange-500/20">
                      arXiv
                    </span>
                  )}
                </div>
              )}
            </div>
            {pub.data.link && (
              <a href={pub.data.link} target="_blank" rel="noopener noreferrer" class="shrink-0 inline-flex items-center px-4 py-2.5 border border-slate-600/50 text-sm font-medium rounded-xl text-white bg-slate-800/50 hover:bg-cyan-500/10 hover:border-cyan-500/30 hover:text-cyan-400 focus:outline-none transition-all duration-200">
                Acessar
                <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
