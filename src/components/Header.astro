---
import { useTranslations } from '../utils/i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: 'pt' | 'en' | 'zh';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const mainLinks = [
  { href: `${base}`, label: t('nav.home') },
  { href: `${base}about`, label: t('nav.about') },
  { href: `${base}science`, label: t('nav.science') },
  { href: `${base}instrumentation`, label: t('nav.instrumentation') },
];

const extensionLinks = [
  { href: `${base}uirapuru`, label: t('nav.uirapuru') },
  { href: `${base}abdus`, label: t('nav.abdus') },
  { href: `${base}outreach`, label: t('nav.outreach') },
  { href: `${base}location`, label: t('nav.location') },
];

const secondaryLinks = [
  { href: `${base}team`, label: t('nav.team') },
  { href: `${base}news`, label: t('nav.news') },
  { href: `${base}publications`, label: t('nav.publications') },
];
---

<header id="site-header" class="fixed w-full top-0 z-50 transition-all duration-300" style="background: rgba(7, 13, 31, 0.85); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(99, 102, 241, 0.08);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href={base} class="flex items-center gap-3 group">
          <!-- Official BINGO logo -->
          <img
            src={`${base}BINGO-Logo-ico.png`}
            alt="BINGO Logo"
            class="h-10 w-auto object-contain drop-shadow-lg group-hover:drop-shadow-[0_0_8px_rgba(34,211,238,0.4)] transition-all duration-300"
          />
          <span class="text-2xl font-extrabold text-white tracking-wider" style="font-family: 'Outfit', sans-serif;">
            <span class="gradient-text-cyan font-bingo">BINGO</span><span class="text-slate-400 font-light ml-1">Telescope</span>
          </span>
        </a>
      </div>

      <!-- Desktop Menu -->
      <nav class="hidden lg:flex items-center space-x-1">
        {mainLinks.map((link) => (
          <a
            href={link.href}
            class="text-slate-300 hover:text-cyan-400 transition-colors duration-200 text-sm font-medium px-3 py-2 rounded-lg hover:bg-white/5"
          >
            {link.label}
          </a>
        ))}

        <!-- Extensões Dropdown -->
        <div class="relative" id="extensions-dropdown">
          <button
            class="text-slate-300 hover:text-cyan-400 transition-colors duration-200 text-sm font-medium px-3 py-2 rounded-lg hover:bg-white/5 inline-flex items-center gap-1"
            id="extensions-btn"
          >
            {t('nav.extensions')}
            <svg class="w-3.5 h-3.5 transition-transform duration-200" id="extensions-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-2 w-56 rounded-xl border border-indigo-500/20 shadow-2xl opacity-0 invisible transition-all duration-200 transform -translate-y-2" id="extensions-menu" style="background: rgba(7, 13, 31, 0.95); backdrop-filter: blur(20px);">
            <div class="py-2 px-1">
              {extensionLinks.map((link) => (
                <a
                  href={link.href}
                  class="block px-4 py-2.5 text-sm text-slate-300 hover:text-cyan-400 hover:bg-white/5 rounded-lg transition-colors"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        {secondaryLinks.map((link) => (
          <a
            href={link.href}
            class="text-slate-300 hover:text-cyan-400 transition-colors duration-200 text-sm font-medium px-3 py-2 rounded-lg hover:bg-white/5"
          >
            {link.label}
          </a>
        ))}

        <!-- Social icons -->
        <a href="https://www.instagram.com/bingotelescopio/" target="_blank" rel="noopener noreferrer" class="ml-2 text-slate-500 hover:text-pink-400 transition-colors p-2 rounded-lg hover:bg-white/5" aria-label="Instagram">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.facebook.com/BINGOTelescopio" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-blue-400 transition-colors p-2 rounded-lg hover:bg-white/5" aria-label="Facebook">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>

        <!-- Language Switcher -->
        <div class="ml-2 border-l border-indigo-500/15 pl-2">
          <LanguageSwitcher />
        </div>
      </nav>

      <!-- Mobile Menu Button -->
      <div class="lg:hidden flex items-center">
        <button id="mobile-menu-btn" class="text-slate-300 hover:text-white focus:outline-none p-2 rounded-lg hover:bg-white/5 transition-colors">
          <svg class="h-6 w-6" id="menu-icon-open" fill="none" viewBox="0 0 24 24" stroke="currentColor">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="h-6 w-6 hidden" id="menu-icon-close" fill="none" viewBox="0 0 24 24" stroke="currentColor">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu (scrollable on small screens, smooth height transition) -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-indigo-500/10 max-h-[calc(100vh-5rem)] overflow-y-auto" style="background: rgba(7, 13, 31, 0.98);">
    <div class="px-4 pt-4 pb-6 space-y-1">
      {mainLinks.map((link) => (
        <a
          href={link.href}
          class="block px-4 py-2.5 rounded-lg text-base font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-colors"
        >
          {link.label}
        </a>
      ))}

      <div class="pt-2 pb-1">
        <p class="px-4 text-xs font-semibold text-indigo-400/60 uppercase tracking-wider">{t('nav.extensions')}</p>
      </div>
      {extensionLinks.map((link) => (
        <a
          href={link.href}
          class="block px-4 py-2.5 rounded-lg text-base font-medium text-slate-400 hover:text-cyan-400 hover:bg-white/5 transition-colors pl-8"
        >
          {link.label}
        </a>
      ))}

      <div class="border-t border-indigo-500/10 my-2"></div>
      {secondaryLinks.map((link) => (
        <a
          href={link.href}
          class="block px-4 py-2.5 rounded-lg text-base font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-colors"
        >
          {link.label}
        </a>
      ))}

      <!-- Mobile Language Switcher -->
      <div class="border-t border-indigo-500/10 my-2 pt-3 px-4">
        <p class="text-xs font-semibold text-indigo-400/60 uppercase tracking-wider mb-2" data-no-translate>🌐 Idioma / Language</p>
        <div class="flex gap-2" data-no-translate>
          <button class="mobile-lang-btn flex-1 px-3 py-2 rounded-lg text-sm font-medium border transition-colors" data-lang="pt">
            🇧🇷 Português
          </button>
          <button class="mobile-lang-btn flex-1 px-3 py-2 rounded-lg text-sm font-medium border transition-colors" data-lang="en">
            🇬🇧 English
          </button>
          <button class="mobile-lang-btn flex-1 px-3 py-2 rounded-lg text-sm font-medium border transition-colors" data-lang="zh">
            🇨🇳 中文
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  if (btn && menu && iconOpen && iconClose) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
    });
  }

  // Extensions dropdown
  const dropdownBtn = document.getElementById('extensions-btn');
  const dropdownMenu = document.getElementById('extensions-menu');
  const chevron = document.getElementById('extensions-chevron');

  if (dropdownBtn && dropdownMenu && chevron) {
    dropdownBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !dropdownMenu.classList.contains('invisible');
      if (isOpen) {
        dropdownMenu.classList.add('opacity-0', 'invisible', '-translate-y-2');
        dropdownMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
        chevron.style.transform = '';
      } else {
        dropdownMenu.classList.remove('opacity-0', 'invisible', '-translate-y-2');
        dropdownMenu.classList.add('opacity-100', 'visible', 'translate-y-0');
        chevron.style.transform = 'rotate(180deg)';
      }
    });

    document.addEventListener('click', () => {
      dropdownMenu.classList.add('opacity-0', 'invisible', '-translate-y-2');
      dropdownMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
      chevron.style.transform = '';
    });
  }

  // Header scroll effect
  const header = document.getElementById('site-header');
  if (header) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.style.background = 'rgba(7, 13, 31, 0.95)';
        header.style.borderBottomColor = 'rgba(99, 102, 241, 0.15)';
      } else {
        header.style.background = 'rgba(7, 13, 31, 0.85)';
        header.style.borderBottomColor = 'rgba(99, 102, 241, 0.08)';
      }
    });
  }
</script>
