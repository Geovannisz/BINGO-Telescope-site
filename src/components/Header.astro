---
import { useTranslations } from '../utils/i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: 'pt' | 'en' | 'zh';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const mainLinks = [
  { href: `${base}`, label: t('nav.home'), key: 'nav.home' },
  { href: `${base}about`, label: t('nav.about'), key: 'nav.about' },
  { href: `${base}science`, label: t('nav.science'), key: 'nav.science' },
  { href: `${base}instrumentation`, label: t('nav.instrumentation'), key: 'nav.instrumentation' },
];

const extensionLinks = [
  { href: `${base}uirapuru`, label: t('nav.uirapuru'), key: 'nav.uirapuru' },
  { href: `${base}abdus`, label: t('nav.abdus'), key: 'nav.abdus' },
  { href: `${base}outreach`, label: t('nav.outreach'), key: 'nav.outreach' },
  { href: `${base}location`, label: t('nav.location'), key: 'nav.location' },
];

const secondaryLinks = [
  { href: `${base}team`, label: t('nav.team'), key: 'nav.team' },
  { href: `${base}news`, label: t('nav.news'), key: 'nav.news' },
  { href: `${base}publications`, label: t('nav.publications'), key: 'nav.publications' },
];

const pathname = new URL(Astro.request.url).pathname;

// Helper to determine if a link is active, matching subpaths correctly
const isActive = (href: string) => {
  const cleanPathname = pathname.replace(/\/$/, "") || "/";
  const cleanHref = href.replace(/\/$/, "") || "/";
  
  if (cleanHref === base.replace(/\/$/, "") || cleanHref === "/") {
    return cleanPathname === cleanHref;
  }
  
  return cleanPathname === cleanHref || cleanPathname.startsWith(cleanHref + '/');
};

const isExtensionActive = extensionLinks.some(link => isActive(link.href));
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 pt-4 px-4 sm:px-6 lg:px-8" translate="no">
  <div id="site-header-inner" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 rounded-2xl transition-all duration-500 border border-indigo-500/10 shadow-lg" style="background: rgba(7, 13, 31, 0.8); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);">
    <div class="flex justify-between items-center h-16 md:h-18">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href={base} class="flex items-center gap-3 group">
          <!-- Official BINGO logo -->
          <img
            src={`${base}BINGO-Logo-ico.png`}
            alt="BINGO Logo"
            class="h-9 md:h-10 w-auto object-contain drop-shadow-lg group-hover:drop-shadow-[0_0_12px_rgba(34,211,238,0.5)] group-hover:scale-105 transition-all duration-300 cursor-pointer"
          />
          <span class="text-xl md:text-2xl font-extrabold text-white tracking-wider" style="font-family: 'Outfit', sans-serif;">
            <span class="gradient-text-cyan font-bingo">BINGO</span><span class="text-slate-400 group-hover:text-white font-light ml-1 transition-colors duration-300">Telescope</span>
          </span>
        </a>
      </div>

      <!-- Desktop Menu -->
      <nav class="hidden lg:flex items-center space-x-1">
        {mainLinks.map((link) => {
          const active = isActive(link.href);
          return (
            <a
              href={link.href}
              class={`transition-all duration-300 text-sm font-medium px-3 py-2 rounded-xl border cursor-pointer ${
                active 
                  ? 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20 shadow-[0_0_12px_rgba(34,211,238,0.15)]' 
                  : 'text-slate-300 border-transparent hover:text-cyan-400 hover:bg-white/5'
              }`}
              data-i18n={link.key}
            >
              {link.label}
            </a>
          );
        })}

        <!-- Extensões Dropdown -->
        <div class="relative" id="extensions-dropdown">
          <button
            class={`transition-all duration-300 text-sm font-medium px-3 py-2 rounded-xl border inline-flex items-center gap-1.5 cursor-pointer ${
              isExtensionActive 
                ? 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20 shadow-[0_0_12px_rgba(34,211,238,0.15)]' 
                : 'text-slate-300 border-transparent hover:text-cyan-400 hover:bg-white/5'
            }`}
            id="extensions-btn"
            data-i18n="nav.extensions"
          >
            {t('nav.extensions')}
            <svg class="w-3 h-3 transition-transform duration-300 text-slate-500" id="extensions-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-2.5 w-56 rounded-2xl border border-indigo-500/20 shadow-[0_20px_50px_rgba(7,13,31,0.6),0_0_30px_rgba(99,102,241,0.15)] opacity-0 invisible transition-all duration-300 transform -translate-y-2 z-[100] p-1.5" id="extensions-menu" style="background: rgba(10, 18, 40, 0.95); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);">
            <div class="space-y-0.5">
              {extensionLinks.map((link) => {
                const active = isActive(link.href);
                return (
                  <a
                    href={link.href}
                    class={`block px-3 py-2.5 text-xs rounded-xl transition-all duration-200 border cursor-pointer ${
                      active
                        ? 'text-cyan-300 bg-cyan-500/10 border-cyan-500/20'
                        : 'text-slate-300 border-transparent hover:text-cyan-300 hover:bg-white/5'
                    }`}
                    data-i18n={link.key}
                  >
                    {link.label}
                  </a>
                );
              })}
            </div>
          </div>
        </div>

        {secondaryLinks.map((link) => {
          const active = isActive(link.href);
          return (
            <a
              href={link.href}
              class={`transition-all duration-300 text-sm font-medium px-3 py-2 rounded-xl border cursor-pointer ${
                active 
                  ? 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20 shadow-[0_0_12px_rgba(34,211,238,0.15)]' 
                  : 'text-slate-300 border-transparent hover:text-cyan-400 hover:bg-white/5'
              }`}
              data-i18n={link.key}
            >
              {link.label}
            </a>
          );
        })}

        <!-- Social icons -->
        <a href="https://www.instagram.com/bingotelescopio/" target="_blank" rel="noopener noreferrer" class="ml-2 text-slate-500 hover:text-pink-400 transition-colors p-2 rounded-xl hover:bg-white/5" aria-label="Instagram">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.facebook.com/BINGOTelescopio" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-blue-400 transition-colors p-2 rounded-xl hover:bg-white/5" aria-label="Facebook">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>

        <!-- Language Switcher -->
        <div class="ml-2 border-l border-indigo-500/15 pl-2">
          <LanguageSwitcher />
        </div>
      </nav>

      <!-- Mobile Menu Button -->
      <div class="lg:hidden flex items-center">
        <button id="mobile-menu-btn" class="text-slate-300 hover:text-white focus:outline-none p-2 rounded-xl hover:bg-white/5 transition-colors cursor-pointer">
          <svg class="h-6 w-6" id="menu-icon-open" fill="none" viewBox="0 0 24 24" stroke="currentColor">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="h-6 w-6 hidden" id="menu-icon-close" fill="none" viewBox="0 0 24 24" stroke="currentColor">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-indigo-500/10 max-h-[calc(100vh-6rem)] overflow-y-auto pb-6" style="background: transparent;">
      <div class="px-2 pt-4 pb-2 space-y-1">
        {mainLinks.map((link) => {
          const active = isActive(link.href);
          return (
            <a
              href={link.href}
              class={`block px-4 py-2.5 rounded-xl text-base font-semibold transition-all duration-300 border cursor-pointer ${
                active
                  ? 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20 pl-6 shadow-[0_0_10px_rgba(34,211,238,0.05)]'
                  : 'text-slate-300 border-transparent hover:text-white hover:bg-white/5'
              }`}
              data-i18n={link.key}
            >
              {link.label}
            </a>
          );
        })}

        <div class="pt-3 pb-1 pl-4">
          <p class="text-xxs font-extrabold text-indigo-400/50 uppercase tracking-widest" data-i18n="nav.extensions">{t('nav.extensions')}</p>
        </div>
        
        {extensionLinks.map((link) => {
          const active = isActive(link.href);
          return (
            <a
              href={link.href}
              class={`block px-4 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 border pl-8 cursor-pointer ${
                active
                  ? 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20 shadow-[0_0_10px_rgba(34,211,238,0.05)]'
                  : 'text-slate-400 border-transparent hover:text-cyan-400 hover:bg-white/5'
              }`}
              data-i18n={link.key}
            >
              {link.label}
            </a>
          );
        })}

        <div class="border-t border-indigo-500/10 my-3"></div>
        
        {secondaryLinks.map((link) => {
          const active = isActive(link.href);
          return (
            <a
              href={link.href}
              class={`block px-4 py-2.5 rounded-xl text-base font-semibold transition-all duration-300 border cursor-pointer ${
                active
                  ? 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20 pl-6 shadow-[0_0_10px_rgba(34,211,238,0.05)]'
                  : 'text-slate-300 border-transparent hover:text-white hover:bg-white/5'
              }`}
              data-i18n={link.key}
            >
              {link.label}
            </a>
          );
        })}

        <!-- Mobile Language Switcher -->
        <div class="border-t border-indigo-500/10 my-3 pt-3 px-4">
          <p class="text-xxs font-extrabold text-indigo-400/50 uppercase tracking-widest mb-2.5" data-no-translate>🌐 Idioma / Language</p>
          <div class="flex gap-2" data-no-translate>
            <button class="mobile-lang-btn flex-1 px-3 py-2.5 rounded-xl text-xs font-semibold border transition-all duration-300 cursor-pointer shadow-[inset_0_1px_0_rgba(255,255,255,0.02)]" data-lang="pt">
              🇧🇷 Português
            </button>
            <button class="mobile-lang-btn flex-1 px-3 py-2.5 rounded-xl text-xs font-semibold border transition-all duration-300 cursor-pointer shadow-[inset_0_1px_0_rgba(255,255,255,0.02)]" data-lang="en">
              🇬🇧 English
            </button>
            <button class="mobile-lang-btn flex-1 px-3 py-2.5 rounded-xl text-xs font-semibold border transition-all duration-300 cursor-pointer shadow-[inset_0_1px_0_rgba(255,255,255,0.02)]" data-lang="zh-CN">
              🇨🇳 中文
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  @keyframes slideDownFade {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .mobile-menu-active {
    display: block !important;
    animation: slideDownFade 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .mobile-menu-active > div > * {
    opacity: 0;
    animation: fadeInUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Staggered delay for child elements */
  .mobile-menu-active > div > *:nth-child(1) { animation-delay: 30ms; }
  .mobile-menu-active > div > *:nth-child(2) { animation-delay: 60ms; }
  .mobile-menu-active > div > *:nth-child(3) { animation-delay: 90ms; }
  .mobile-menu-active > div > *:nth-child(4) { animation-delay: 120ms; }
  .mobile-menu-active > div > *:nth-child(5) { animation-delay: 150ms; }
  .mobile-menu-active > div > *:nth-child(6) { animation-delay: 180ms; }
  .mobile-menu-active > div > *:nth-child(7) { animation-delay: 210ms; }
  .mobile-menu-active > div > *:nth-child(8) { animation-delay: 240ms; }
  .mobile-menu-active > div > *:nth-child(9) { animation-delay: 270ms; }
  .mobile-menu-active > div > *:nth-child(10) { animation-delay: 300ms; }
  .mobile-menu-active > div > *:nth-child(11) { animation-delay: 330ms; }
  .mobile-menu-active > div > *:nth-child(12) { animation-delay: 360ms; }
  .mobile-menu-active > div > *:nth-child(13) { animation-delay: 390ms; }
  .mobile-menu-active > div > *:nth-child(14) { animation-delay: 420ms; }
</style>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  if (btn && menu && iconOpen && iconClose) {
    btn.addEventListener('click', () => {
      const isHidden = menu.classList.contains('hidden');
      if (isHidden) {
        menu.classList.remove('hidden');
        menu.classList.add('mobile-menu-active');
        iconOpen.classList.add('hidden');
        iconClose.classList.remove('hidden');
      } else {
        menu.classList.add('hidden');
        menu.classList.remove('mobile-menu-active');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
      }
    });
  }

  // Extensions dropdown
  const dropdownBtn = document.getElementById('extensions-btn');
  const dropdownMenu = document.getElementById('extensions-menu');
  const chevron = document.getElementById('extensions-chevron');

  if (dropdownBtn && dropdownMenu && chevron) {
    dropdownBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !dropdownMenu.classList.contains('invisible');
      if (isOpen) {
        dropdownMenu.classList.add('opacity-0', 'invisible', '-translate-y-2');
        dropdownMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
        chevron.style.transform = '';
      } else {
        dropdownMenu.classList.remove('opacity-0', 'invisible', '-translate-y-2');
        dropdownMenu.classList.add('opacity-100', 'visible', 'translate-y-0');
        chevron.style.transform = 'rotate(180deg)';
      }
    });

    document.addEventListener('click', () => {
      dropdownMenu.classList.add('opacity-0', 'invisible', '-translate-y-2');
      dropdownMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
      chevron.style.transform = '';
    });
  }

  // Header scroll effect
  const header = document.getElementById('site-header');
  const headerInner = document.getElementById('site-header-inner');
  if (header && headerInner) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.classList.remove('pt-4');
        header.classList.add('pt-2');
        headerInner.style.background = 'rgba(7, 13, 31, 0.95)';
        headerInner.style.borderColor = 'rgba(34, 211, 238, 0.2)';
        headerInner.style.boxShadow = '0 10px 30px rgba(7, 13, 31, 0.5), 0 0 20px rgba(99, 102, 241, 0.1)';
      } else {
        header.classList.remove('pt-2');
        header.classList.add('pt-4');
        headerInner.style.background = 'rgba(7, 13, 31, 0.8)';
        headerInner.style.borderColor = 'rgba(99, 102, 241, 0.08)';
        headerInner.style.boxShadow = 'none';
      }
    });
  }
</script>
