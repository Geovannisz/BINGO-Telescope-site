---
import { useTranslations } from '../utils/i18n';

interface Props {
  lang: 'pt' | 'en' | 'zh';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const navLinks = [
  { href: `${base}`, label: t('nav.home') },
  { href: `${base}about`, label: t('nav.about') },
  { href: `${base}science`, label: t('nav.science') },
  { href: `${base}instrumentation`, label: t('nav.instrumentation') },
  { href: `${base}team`, label: t('nav.team') },
  { href: `${base}news`, label: t('nav.news') },
  { href: `${base}publications`, label: t('nav.publications') },
];
---

<header class="fixed w-full top-0 z-50 bg-slate-900/90 backdrop-blur-md border-b border-slate-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <div class="flex-shrink-0 flex items-center">
        <a href={base} class="text-2xl font-bold text-white tracking-wider flex items-center gap-2">
          <span class="text-cyan-400">BINGO</span> Telescope
        </a>
      </div>

      <!-- Desktop Menu -->
      <nav class="hidden md:flex space-x-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-slate-300 hover:text-cyan-400 transition-colors duration-200 text-sm font-medium"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile Menu Button -->
      <div class="md:hidden flex items-center">
        <button id="mobile-menu-btn" class="text-slate-300 hover:text-white focus:outline-none">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-slate-900 border-b border-slate-800">
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-slate-800"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  if(btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
