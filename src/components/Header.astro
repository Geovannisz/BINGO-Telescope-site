---
import { useTranslations } from '../utils/i18n';

interface Props {
  lang: 'pt' | 'en' | 'zh';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const mainLinks = [
  { href: `${base}`, label: t('nav.home') },
  { href: `${base}about`, label: t('nav.about') },
  { href: `${base}science`, label: t('nav.science') },
  { href: `${base}instrumentation`, label: t('nav.instrumentation') },
];

const subprojectLinks = [
  { href: `${base}uirapuru`, label: t('nav.uirapuru') },
  { href: `${base}abdus`, label: t('nav.abdus') },
  { href: `${base}outreach`, label: t('nav.outreach') },
  { href: `${base}location`, label: t('nav.location') },
];

const secondaryLinks = [
  { href: `${base}team`, label: t('nav.team') },
  { href: `${base}news`, label: t('nav.news') },
  { href: `${base}publications`, label: t('nav.publications') },
];
---

<header id="site-header" class="fixed w-full top-0 z-50 transition-all duration-300" style="background: rgba(10, 22, 40, 0.85); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid rgba(148, 163, 184, 0.08);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href={base} class="flex items-center gap-3 group">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-cyan-400 to-cyan-600 flex items-center justify-center shadow-lg shadow-cyan-500/20 group-hover:shadow-cyan-500/40 transition-shadow">
            <span class="text-white font-black text-sm">B</span>
          </div>
          <span class="text-2xl font-extrabold text-white tracking-wider">
            <span class="text-cyan-400">BINGO</span><span class="text-slate-400 font-light ml-1">Telescope</span>
          </span>
        </a>
      </div>

      <!-- Desktop Menu -->
      <nav class="hidden lg:flex items-center space-x-1">
        {mainLinks.map((link) => (
          <a
            href={link.href}
            class="text-slate-300 hover:text-cyan-400 transition-colors duration-200 text-sm font-medium px-3 py-2 rounded-lg hover:bg-white/5"
          >
            {link.label}
          </a>
        ))}

        <!-- Subprojetos Dropdown -->
        <div class="relative" id="subprojects-dropdown">
          <button
            class="text-slate-300 hover:text-cyan-400 transition-colors duration-200 text-sm font-medium px-3 py-2 rounded-lg hover:bg-white/5 inline-flex items-center gap-1"
            id="subprojects-btn"
          >
            {t('nav.subprojects')}
            <svg class="w-3.5 h-3.5 transition-transform duration-200" id="subprojects-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-2 w-56 rounded-xl border border-slate-700/50 shadow-2xl opacity-0 invisible transition-all duration-200 transform -translate-y-2" id="subprojects-menu" style="background: rgba(15, 23, 42, 0.95); backdrop-filter: blur(20px);">
            <div class="py-2 px-1">
              {subprojectLinks.map((link) => (
                <a
                  href={link.href}
                  class="block px-4 py-2.5 text-sm text-slate-300 hover:text-cyan-400 hover:bg-white/5 rounded-lg transition-colors"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        {secondaryLinks.map((link) => (
          <a
            href={link.href}
            class="text-slate-300 hover:text-cyan-400 transition-colors duration-200 text-sm font-medium px-3 py-2 rounded-lg hover:bg-white/5"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile Menu Button -->
      <div class="lg:hidden flex items-center">
        <button id="mobile-menu-btn" class="text-slate-300 hover:text-white focus:outline-none p-2 rounded-lg hover:bg-white/5 transition-colors">
          <svg class="h-6 w-6" id="menu-icon-open" fill="none" viewBox="0 0 24 24" stroke="currentColor">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="h-6 w-6 hidden" id="menu-icon-close" fill="none" viewBox="0 0 24 24" stroke="currentColor">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-slate-800/50" style="background: rgba(10, 22, 40, 0.98);">
    <div class="px-4 pt-4 pb-6 space-y-1">
      {mainLinks.map((link) => (
        <a
          href={link.href}
          class="block px-4 py-2.5 rounded-lg text-base font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-colors"
        >
          {link.label}
        </a>
      ))}

      <div class="pt-2 pb-1">
        <p class="px-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">{t('nav.subprojects')}</p>
      </div>
      {subprojectLinks.map((link) => (
        <a
          href={link.href}
          class="block px-4 py-2.5 rounded-lg text-base font-medium text-slate-400 hover:text-cyan-400 hover:bg-white/5 transition-colors pl-8"
        >
          {link.label}
        </a>
      ))}

      <div class="border-t border-slate-800/50 my-2"></div>
      {secondaryLinks.map((link) => (
        <a
          href={link.href}
          class="block px-4 py-2.5 rounded-lg text-base font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  if (btn && menu && iconOpen && iconClose) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
    });
  }

  // Subprojects dropdown
  const dropdownBtn = document.getElementById('subprojects-btn');
  const dropdownMenu = document.getElementById('subprojects-menu');
  const chevron = document.getElementById('subprojects-chevron');

  if (dropdownBtn && dropdownMenu && chevron) {
    dropdownBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !dropdownMenu.classList.contains('invisible');
      if (isOpen) {
        dropdownMenu.classList.add('opacity-0', 'invisible', '-translate-y-2');
        dropdownMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
        chevron.style.transform = '';
      } else {
        dropdownMenu.classList.remove('opacity-0', 'invisible', '-translate-y-2');
        dropdownMenu.classList.add('opacity-100', 'visible', 'translate-y-0');
        chevron.style.transform = 'rotate(180deg)';
      }
    });

    document.addEventListener('click', () => {
      dropdownMenu.classList.add('opacity-0', 'invisible', '-translate-y-2');
      dropdownMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
      chevron.style.transform = '';
    });
  }

  // Header scroll effect
  const header = document.getElementById('site-header');
  if (header) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.style.background = 'rgba(10, 22, 40, 0.95)';
        header.style.borderBottomColor = 'rgba(148, 163, 184, 0.15)';
      } else {
        header.style.background = 'rgba(10, 22, 40, 0.85)';
        header.style.borderBottomColor = 'rgba(148, 163, 184, 0.08)';
      }
    });
  }
</script>
