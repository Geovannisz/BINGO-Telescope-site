---
/* ===================================================================
   TEAM MEMBER CARD COMPONENT
   
   Displays a single team member with:
   - Circular photo (with person icon fallback)
   - Name, role, institution
   
   PROPS:
   - name: string (required) — Full name
   - role: string (required) — Position/title
   - institution: string (required) — University/institute
   - photo: string (optional) — Path to photo image (relative to public/)
   
   STYLING:
   - Uses glass-card-glow design tokens from global.css
   - Photo is 96px (w-24/h-24) on desktop, 80px (w-20/h-20) on mobile
   - Hover effect lifts card and highlights border
   =================================================================== */
interface Props {
  name: string;
  role: string;
  institution: string;
  photo?: string;
}

const { name, role, institution, photo } = Astro.props;
const base = import.meta.env.BASE_URL;

/* If photo path is provided but doesn't start with http or base, prepend base */
const photoSrc = photo
  ? (photo.startsWith('http') || photo.startsWith(base))
    ? photo
    : `${base}${photo.startsWith('/') ? photo.slice(1) : photo}`
  : null;
---

<div class="bg-slate-800/40 rounded-xl border border-slate-700/50 p-4 sm:p-6 flex flex-col items-center text-center transition-all duration-300 hover:bg-slate-800 hover:border-slate-600 hover:shadow-lg hover:shadow-cyan-500/5">
  <!-- Photo circle -->
  <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full overflow-hidden mb-3 sm:mb-4 bg-slate-700 border-2 border-slate-600 flex-shrink-0">
    {photoSrc ? (
      <img
        src={photoSrc}
        alt={`Foto de ${name}`}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-slate-400">
        <svg class="w-10 h-10 sm:w-12 sm:h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </div>
    )}
  </div>
  <!-- Member info -->
  <h3 class="text-base sm:text-lg font-bold text-white mb-1 leading-snug">{name}</h3>
  <p class="text-cyan-400 text-xs sm:text-sm font-medium mb-1.5 sm:mb-2">{role}</p>
  <p class="text-slate-400 text-[0.65rem] sm:text-xs uppercase tracking-wider leading-tight">{institution}</p>
</div>
