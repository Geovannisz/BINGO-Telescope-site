---
/* ===================================================================
   TEAM MEMBER CARD COMPONENT
   
   Displays a single team member with:
   - Circular photo (with person icon fallback)
   - Name, role, institution, stage badge
   - Clickable: links to individual profile page
   
   PROPS:
   - name: string (required) — Full name
   - role: string (required) — Position/title
   - institution: string (required) — University/institute
   - photo: string (optional) — Path to photo image
   - stage: string (optional) — Working group stage
   - slug: string (required) — URL slug for profile page
   =================================================================== */
interface Props {
  name: string;
  role: string;
  institution: string;
  photo?: string;
  stage?: string[];
  slug: string;
}

const { name, role, institution, photo, stage, slug } = Astro.props;
const base = import.meta.env.BASE_URL;

/* If photo path is provided but doesn't start with http or base, prepend base */
const photoSrc = photo
  ? (photo.startsWith('http') || photo.startsWith(base))
    ? photo
    : `${base}${photo.startsWith('/') ? photo.slice(1) : photo}`
  : null;

/* Stage color mapping */
const stageColors: Record<string, string> = {
  'Stage 0': 'bg-rose-500/15 text-rose-400 border-rose-500/30',
  'Stage I': 'bg-orange-500/15 text-orange-400 border-orange-500/30',
  'Stage II': 'bg-amber-500/15 text-amber-400 border-amber-500/30',
  'Stage III': 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30',
  'Stage IV': 'bg-blue-500/15 text-blue-400 border-blue-500/30',
  'Stage V': 'bg-purple-500/15 text-purple-400 border-purple-500/30',
  'Coordenação': 'bg-cyan-500/15 text-cyan-400 border-cyan-500/30',
};
const stagesArray = stage || [];
---

<a href={`${base}team/${slug}/`} class="group block">
  <div class="bg-slate-800/40 rounded-xl border border-slate-700/50 p-4 sm:p-6 flex flex-col items-center text-center transition-all duration-300 group-hover:bg-slate-800/70 group-hover:border-indigo-500/40 group-hover:shadow-lg group-hover:shadow-cyan-500/10 group-hover:-translate-y-1">
    <!-- Photo circle -->
    <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full overflow-hidden mb-3 sm:mb-4 bg-slate-700 border-2 border-slate-600 flex-shrink-0 transition-all duration-300 group-hover:border-cyan-500/50 group-hover:shadow-md group-hover:shadow-cyan-500/20">
      {photoSrc ? (
        <img
          src={photoSrc}
          alt={`Foto de ${name}`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center text-slate-400">
          <svg class="w-10 h-10 sm:w-12 sm:h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
      )}
    </div>
    <!-- Member info -->
    <h3 class="text-base sm:text-lg font-bold text-white mb-1 leading-snug group-hover:text-cyan-300 transition-colors duration-200">{name}</h3>
    <p class="text-cyan-400 text-xs sm:text-sm font-medium mb-1.5 sm:mb-2">{role}</p>
    <p class="text-slate-400 text-[0.65rem] sm:text-xs uppercase tracking-wider leading-tight mb-2">{institution}</p>
    <div class="flex flex-wrap justify-center gap-1.5 mt-2">
      {stagesArray.map((s) => {
        const sClass = stageColors[s] || 'bg-slate-500/15 text-slate-400 border-slate-500/30';
        return (
          <span class={`inline-block text-[0.6rem] sm:text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full border ${sClass}`}>
            {s}
          </span>
        );
      })}
    </div>
  </div>
</a>
