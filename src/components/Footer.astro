---
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="relative mt-auto overflow-hidden" style="background: linear-gradient(180deg, #0f172a 0%, #070d1f 100%);">
  <!-- Partners Bar -->
  <div class="partners-bar">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-xs text-slate-500 uppercase tracking-wider mb-4 font-medium">Financiadores e Parceiros</p>
      <div class="w-full overflow-x-auto pb-4 custom-scrollbar">
        <div class="flex justify-center min-w-[1000px] lg:min-w-full">
          <img src={`${base}images/logos/Regua-de-logos-bco-1536x200.png`} alt="Logos dos parceiros e financiadores do BINGO" class="h-24 md:h-36 lg:h-48 w-auto object-contain" />
        </div>
      </div>
    </div>
  </div>

  <!-- Background texture -->
  <div class="absolute inset-0 opacity-[0.03]" style={`background-image: url('${base}images/backgrounds/cmb_planck-background.png'); background-size: cover; background-position: center;`}></div>

  <div class="relative pt-16 pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
        <div class="col-span-1 md:col-span-1">
          <a href={base} class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-cyan-400 via-indigo-500 to-cyan-600 flex items-center justify-center">
              <span class="text-white font-black text-xs">B</span>
            </div>
            <span class="text-xl font-extrabold text-white tracking-wider" style="font-family: 'Outfit', sans-serif;">
              <span class="gradient-text-cyan">BINGO</span><span class="text-slate-400 font-light ml-1">Telescope</span>
            </span>
          </a>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">
            Baryon Acoustic Oscillations from Integrated Neutral Gas Observations. Mapeando o universo em rádio para entender a energia escura.
          </p>
          <!-- Social Links -->
          <div class="flex gap-3 mt-4">
            <a href="https://www.instagram.com/bingotelescopio/" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-pink-400 hover:border-pink-500/30 hover:bg-pink-500/10 transition-all" aria-label="Instagram">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="https://www.youtube.com/@bingotelescopio" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-red-400 hover:border-red-500/30 hover:bg-red-500/10 transition-all" aria-label="YouTube">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
            <a href="https://bingotelescope.org" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-cyan-400 hover:border-cyan-500/30 hover:bg-cyan-500/10 transition-all" aria-label="Site Oficial">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
            </a>
          </div>
        </div>

        <div>
          <h3 class="text-white font-semibold mb-4 uppercase tracking-wider text-sm" style="font-family: 'Outfit', sans-serif;">O Projeto</h3>
          <ul class="space-y-2">
            <li><a href={`${base}about`} class="text-slate-400 hover:text-cyan-400 text-sm transition-colors">Sobre</a></li>
            <li><a href={`${base}science`} class="text-slate-400 hover:text-cyan-400 text-sm transition-colors">Ciência</a></li>
            <li><a href={`${base}instrumentation`} class="text-slate-400 hover:text-cyan-400 text-sm transition-colors">Instrumentação</a></li>
            <li><a href={`${base}location`} class="text-slate-400 hover:text-cyan-400 text-sm transition-colors">Localização</a></li>
            <li><a href={`${base}team`} class="text-slate-400 hover:text-cyan-400 text-sm transition-colors">Equipe</a></li>
          </ul>
        </div>

        <div>
          <h3 class="text-white font-semibold mb-4 uppercase tracking-wider text-sm" style="font-family: 'Outfit', sans-serif;">Extensões</h3>
          <ul class="space-y-2">
            <li><a href={`${base}uirapuru`} class="text-slate-400 hover:text-cyan-400 text-sm transition-colors">BINGO-Uirapuru</a></li>
            <li><a href={`${base}abdus`} class="text-slate-400 hover:text-cyan-400 text-sm transition-colors">BINGO-ABDUS</a></li>
            <li><a href={`${base}outreach`} class="text-slate-400 hover:text-cyan-400 text-sm transition-colors">Divulgação Científica</a></li>
            <li><a href={`${base}news`} class="text-slate-400 hover:text-cyan-400 text-sm transition-colors">Notícias</a></li>
            <li><a href={`${base}publications`} class="text-slate-400 hover:text-cyan-400 text-sm transition-colors">Publicações</a></li>
          </ul>
        </div>

        <div>
          <h3 class="text-white font-semibold mb-4 uppercase tracking-wider text-sm" style="font-family: 'Outfit', sans-serif;">Contato</h3>
          <ul class="space-y-3 text-sm text-slate-400">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-cyan-400/60" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              info@bingotelescope.org
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-cyan-400/60" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              Universidade de São Paulo (USP)
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-cyan-400/60" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Aguiar, Paraíba — Brasil
            </li>
          </ul>
        </div>
      </div>

      <div class="border-t border-indigo-500/10 pt-8 flex flex-col md:flex-row justify-between items-center">
        <p class="text-slate-500 text-sm">
          &copy; {currentYear} BINGO Telescope Consortium. Todos os direitos reservados.
        </p>
        <p class="mt-2 md:mt-0 text-slate-600 text-xs">
          Sucessor de <a href="https://bingotelescope.org" target="_blank" rel="noopener noreferrer" class="text-indigo-400/60 hover:text-cyan-400 transition-colors">bingotelescope.org</a>
        </p>
      </div>
    </div>
  </div>
</footer>
