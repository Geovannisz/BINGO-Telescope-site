---
import { useTranslations } from '../utils/i18n';

interface Props {
  lang?: 'pt' | 'en' | 'zh';
}

const { lang = 'pt' } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
---

<div class="relative overflow-hidden min-h-[80vh] sm:min-h-[95vh] flex items-center" style="background: #050a18;">
  <!-- Starfield background -->
  <div class="starfield"></div>

  <!-- Galaxy Background Image with Overlay -->
  <div class="absolute inset-0 z-[1]">
    <img
      src={`${base}images/backgrounds/galaxy-background.jpg`}
      alt="Galáxia — Fundo cósmico"
      class="w-full h-full object-cover opacity-60"
      loading="eager"
      style="animation: subtle-zoom 40s ease-in-out infinite alternate;"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#050a18]/40 via-[#070d1f]/50 to-[#0f172a]"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#070d1f]/50 via-transparent to-[#070d1f]/40"></div>
    <!-- Radial glow effect -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 40%, rgba(99, 102, 241, 0.08) 0%, transparent 60%);"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Text Content -->
      <div>
        <!-- Location badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-indigo-500/30 bg-indigo-500/10 text-cyan-300 text-sm font-medium mb-6 backdrop-blur-sm animate-fade-in-up">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          {t('hero.badge')}
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black tracking-tight mb-6 leading-[1.05] animate-fade-in-up delay-100" style="font-family: 'Outfit', sans-serif;">
          <span class="text-white">Desvendando o</span><br>
          <span class="gradient-text">Universo Escuro</span>
        </h1>

        <p class="text-lg md:text-xl text-slate-300 mb-10 leading-relaxed font-light max-w-xl animate-fade-in-up delay-200">
          {t('hero.subtitle')}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up delay-300">
          <a
            href={`${base}science`}
            class="inline-flex justify-center items-center px-8 py-4 border border-transparent text-base font-semibold rounded-xl text-white bg-gradient-to-r from-cyan-500 to-indigo-500 hover:from-cyan-400 hover:to-indigo-400 focus:outline-none transition-all duration-200 shadow-[0_0_25px_rgba(34,211,238,0.25)] hover:shadow-[0_0_40px_rgba(99,102,241,0.4)] hover:-translate-y-0.5"
          >
            {t('hero.cta1')}
            <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
          <a
            href={`${base}news`}
            class="inline-flex justify-center items-center px-8 py-4 border border-slate-600 text-base font-semibold rounded-xl text-white hover:bg-white/5 hover:border-indigo-500/40 focus:outline-none transition-all duration-200 backdrop-blur-sm"
          >
            {t('hero.cta2')}
          </a>
        </div>

        <!-- Quick Stats -->
        <div class="mt-10 sm:mt-12 grid grid-cols-2 sm:flex sm:flex-wrap gap-6 sm:gap-8 animate-fade-in-up delay-400">
          <div>
            <div class="text-2xl font-extrabold gradient-text-cyan" style="font-family: 'Outfit', sans-serif;">~40m</div>
            <div class="text-xs text-slate-400 uppercase tracking-wider mt-0.5">Espelhos</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold gradient-text-cyan" style="font-family: 'Outfit', sans-serif;">28</div>
            <div class="text-xs text-slate-400 uppercase tracking-wider mt-0.5">Cornetas</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold gradient-text-cyan" style="font-family: 'Outfit', sans-serif;">980–1260</div>
            <div class="text-xs text-slate-400 uppercase tracking-wider mt-0.5">MHz</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold gradient-text-cyan" style="font-family: 'Outfit', sans-serif;">0.13–0.45</div>
            <div class="text-xs text-slate-400 uppercase tracking-wider mt-0.5">Redshift</div>
          </div>
        </div>
      </div>

      <!-- Right: YouTube Video -->
      <div class="animate-fade-in-up delay-300">
        <div class="video-container animate-glow">
          <iframe
            src="https://www.youtube.com/embed/iB6xn86tKOA?rel=0&modestbranding=1"
            title="Apresentação do Telescópio BINGO"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
        <p class="text-center text-slate-500 text-sm mt-3">
          Vídeo de apresentação do projeto BINGO
        </p>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-fade-in delay-600">
    <div class="w-6 h-10 rounded-full border-2 border-indigo-500/30 flex items-start justify-center p-1.5">
      <div class="w-1.5 h-3 bg-cyan-400/60 rounded-full animate-float"></div>
    </div>
  </div>
</div>
