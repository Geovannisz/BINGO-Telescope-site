---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishDate?: Date | string;
  author?: string;
  lang?: string;
}

const {
  title,
  description = "BINGO Telescope - Baryon Acoustic Oscillations from Integrated Neutral Gas Observations. Mapping the universe in radio frequencies to understand dark energy.",
  image = "/images/telescope/BINGO_model_1.jpeg",
  article = false,
  publishDate,
  author,
  lang = "pt",
} = Astro.props;

// Compute canonical URL and Absolute Image URL
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
const imageURL = new URL(image, Astro.site || Astro.url.origin);

// Schema.org JSON-LD
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "BINGO Telescope",
  "url": Astro.site ? Astro.site.toString() : Astro.url.origin,
  "logo": new URL("/BINGO-Logo-ico.png", Astro.site || Astro.url.origin).toString(),
  "sameAs": [
    "https://www.instagram.com/bingotelescopio/",
    "https://www.youtube.com/@bingotelescope",
    "https://www.facebook.com/BINGOTelescopio"
  ]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "BINGO Telescope",
  "url": Astro.site ? Astro.site.toString() : Astro.url.origin,
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${Astro.site ? Astro.site.toString() : Astro.url.origin}/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const articleSchema = article ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": imageURL.toString(),
  "author": {
    "@type": "Person",
    "name": author || "BINGO Team"
  },
  "publisher": {
    "@type": "Organization",
    "name": "BINGO Telescope Consortium",
    "logo": {
      "@type": "ImageObject",
      "url": new URL("/BINGO-Logo-ico.png", Astro.site || Astro.url.origin).toString()
    }
  },
  "datePublished": publishDate ? new Date(publishDate).toISOString() : undefined,
} : null;

// Generate BreadcrumbList
const pathParts = Astro.url.pathname.split('/').filter(p => p !== '' && p !== 'BINGO-Telescope-site');
const breadcrumbItems = pathParts.map((part, index) => {
  const url = `${Astro.site ? Astro.site.toString().replace(/\/$/, '') : Astro.url.origin}/${pathParts.slice(0, index + 1).join('/')}`;
  return {
    "@type": "ListItem",
    "position": index + 2, // 1 is Home
    "name": part.charAt(0).toUpperCase() + part.slice(1).replace(/-/g, ' '),
    "item": url
  };
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": Astro.site ? Astro.site.toString() : Astro.url.origin
    },
    ...breadcrumbItems
  ]
};

// Hreflang alternates: BINGO supports EN, PT, ZH via translation
const locales = ['en', 'pt', 'zh-CN'];
---

<!-- Global SEO Meta Tags -->
<title>{title} | BINGO Telescope</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="theme-color" content="#070d1f" />
<link rel="apple-touch-icon" href={`${Astro.site ? Astro.site.toString().replace(/\/$/, '') : Astro.url.origin}/BINGO-Logo-ico.png`} />

<!-- Language Alternates for SEO -->
{locales.map((locale) => (
  <link rel="alternate" hreflang={locale} href={canonicalURL} />
))}
<link rel="alternate" hreflang="x-default" href={canonicalURL} />

<!-- Open Graph / Facebook / LinkedIn -->
<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={`${title} | BINGO Telescope`} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:site_name" content="BINGO Telescope" />
<meta property="og:locale" content={lang === 'pt' ? 'pt_BR' : lang === 'zh-CN' ? 'zh_CN' : 'en_US'} />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={`${title} | BINGO Telescope`} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />

<!-- Article Specific Tags -->
{article && publishDate && <meta property="article:published_time" content={new Date(publishDate).toISOString()} />}
{article && author && <meta property="article:author" content={author} />}

<!-- JSON-LD Structured Data -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
{articleSchema && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}
