---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishDate?: Date | string;
  author?: string;
  lang?: string;
}

const {
  title,
  description = "Telescópio BINGO — Baryon Acoustic Oscillations from Integrated Neutral Gas Observations. Radiotelescópio em construção na Paraíba, Brasil, dedicado a mapear a distribuição de hidrogênio neutro no universo para investigar a energia escura.",
  image = "/images/telescope/BINGO_model_1.jpeg",
  article = false,
  publishDate,
  author,
  lang = "pt",
} = Astro.props;

// Compute canonical URL and Absolute Image URL
const siteOrigin = Astro.site ? Astro.site.toString().replace(/\/$/, '') : Astro.url.origin;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
const imageURL = new URL(image, Astro.site || Astro.url.origin);

// Schema.org JSON-LD — Organization
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "ResearchOrganization",
  "name": "BINGO Telescope Consortium",
  "alternateName": "BINGO — Baryon Acoustic Oscillations from Integrated Neutral Gas Observations",
  "url": `${siteOrigin}/`,
  "logo": {
    "@type": "ImageObject",
    "url": `${siteOrigin}/BINGO-Logo-ico.png`,
    "width": 512,
    "height": 512
  },
  "description": "Consórcio internacional dedicado à construção e operação do radiotelescópio BINGO para mapeamento de intensidade de hidrogênio neutro (HI) e estudo da energia escura via oscilações acústicas de bárions (BAO).",
  "foundingDate": "2012",
  "location": {
    "@type": "Place",
    "name": "Serra do Urubu, Aguiar, Paraíba, Brasil",
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -7.04,
      "longitude": -38.27
    }
  },
  "sameAs": [
    "https://www.instagram.com/bingotelescopio/",
    "https://www.youtube.com/@bingotelescope",
    "https://www.facebook.com/BINGOTelescopio"
  ],
  "parentOrganization": {
    "@type": "EducationalOrganization",
    "name": "Universidade de São Paulo (USP)",
    "url": "https://www.usp.br"
  }
};

// Schema.org JSON-LD — WebSite (without fictional SearchAction)
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "BINGO Telescope",
  "alternateName": "Telescópio BINGO",
  "url": `${siteOrigin}/`,
  "inLanguage": ["pt-BR", "en", "zh-CN"],
  "publisher": {
    "@type": "ResearchOrganization",
    "name": "BINGO Telescope Consortium"
  }
};

// Schema.org JSON-LD — Article (for news pages)
const articleSchema = article ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": imageURL.toString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL.toString()
  },
  "author": {
    "@type": author === "BINGO Team" ? "Organization" : "Person",
    "name": author || "BINGO Team"
  },
  "publisher": {
    "@type": "Organization",
    "name": "BINGO Telescope Consortium",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteOrigin}/BINGO-Logo-ico.png`
    }
  },
  "datePublished": publishDate ? new Date(publishDate).toISOString() : undefined,
  "dateModified": publishDate ? new Date(publishDate).toISOString() : undefined,
} : null;

// Generate BreadcrumbList
const pathParts = Astro.url.pathname.split('/').filter(p => p !== '');
const breadcrumbItems = pathParts.map((part, index) => {
  const url = `${siteOrigin}/${pathParts.slice(0, index + 1).join('/')}`;
  return {
    "@type": "ListItem",
    "position": index + 2, // 1 is Home
    "name": part.charAt(0).toUpperCase() + part.slice(1).replace(/-/g, ' '),
    "item": url
  };
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": `${siteOrigin}/`
    },
    ...breadcrumbItems
  ]
};
---

<!-- Global SEO Meta Tags -->
<title>{title} | BINGO Telescope</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="theme-color" content="#070d1f" />
<link rel="apple-touch-icon" sizes="180x180" href={`${siteOrigin}/BINGO-Logo-ico.png`} />

<!-- Geo tags for location-aware search -->
<meta name="geo.region" content="BR-PB" />
<meta name="geo.placename" content="Aguiar, Paraíba" />
<meta name="geo.position" content="-7.04;-38.27" />
<meta name="ICBM" content="-7.04, -38.27" />

<!-- Open Graph / Facebook / LinkedIn -->
<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={`${title} | BINGO Telescope`} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${title} — BINGO Telescope`} />
<meta property="og:site_name" content="BINGO Telescope" />
<meta property="og:locale" content={lang === 'pt' ? 'pt_BR' : lang === 'zh-CN' ? 'zh_CN' : 'en_US'} />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={`${title} | BINGO Telescope`} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content={`${title} — BINGO Telescope`} />

<!-- Article Specific Tags -->
{article && publishDate && <meta property="article:published_time" content={new Date(publishDate).toISOString()} />}
{article && author && <meta property="article:author" content={author} />}
{article && <meta property="article:section" content="Ciência" />}
{article && <meta property="article:tag" content="radiotelescópio" />}
{article && <meta property="article:tag" content="cosmologia" />}
{article && <meta property="article:tag" content="BINGO" />}

<!-- JSON-LD Structured Data -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
{articleSchema && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}
