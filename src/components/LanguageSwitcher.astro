---
/**
 * Language Switcher Component
 * A sleek dropdown that matches the BINGO site's cosmic dark theme.
 * Shows flags + language names, persists choice in localStorage.
 */
---

<div class="relative" id="lang-switcher" data-no-translate>
  <button
    id="lang-switcher-btn"
    class="flex items-center gap-2 px-3 py-2 rounded-xl text-slate-400 hover:text-cyan-400 hover:bg-white/5 bg-slate-900/40 border border-slate-800 hover:border-cyan-500/30 transition-all duration-300 text-sm font-medium shadow-[inset_0_1px_1px_rgba(255,255,255,0.05)] cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500/50 focus-visible:border-cyan-500/30"
    aria-label="Mudar idioma"
    title="Mudar idioma"
    aria-haspopup="true"
    aria-expanded="false"
    aria-controls="lang-switcher-menu"
  >
    <span id="lang-switcher-flag" class="text-base leading-none transition-transform duration-300 group-hover:scale-110" aria-hidden="true">🇧🇷</span>
    <span id="lang-switcher-label" class="hidden sm:inline tracking-wide font-semibold text-xs">PT</span>
    <svg class="w-3 h-3 transition-transform duration-300 text-slate-500" id="lang-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div
    id="lang-switcher-menu"
    class="absolute top-full right-0 mt-2.5 w-48 rounded-2xl border border-indigo-500/20 shadow-[0_20px_50px_rgba(7,13,31,0.6),0_0_30px_rgba(99,102,241,0.15)] opacity-0 invisible transition-all duration-300 transform -translate-y-2 z-[100] p-1.5 overflow-hidden"
    style="background: rgba(10, 18, 40, 0.95); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);"
    data-no-translate
  >
    <div class="space-y-0.5">
      <button
        class="lang-option w-full flex items-center gap-3 px-3 py-2.5 text-xs text-slate-300 hover:text-cyan-300 hover:bg-cyan-500/10 rounded-xl transition-all duration-200 text-left cursor-pointer border border-transparent hover:border-cyan-500/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500/50 focus-visible:border-cyan-500/30"
        data-lang="pt"
      >
        <span class="text-base leading-none" aria-hidden="true">🇧🇷</span>
        <span class="font-medium tracking-wide">Português</span>
        <span class="lang-check ml-auto text-cyan-400 opacity-0 transition-opacity duration-200">✓</span>
      </button>
      <button
        class="lang-option w-full flex items-center gap-3 px-3 py-2.5 text-xs text-slate-300 hover:text-cyan-300 hover:bg-cyan-500/10 rounded-xl transition-all duration-200 text-left cursor-pointer border border-transparent hover:border-cyan-500/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500/50 focus-visible:border-cyan-500/30"
        data-lang="en"
      >
        <span class="text-base leading-none" aria-hidden="true">🇬🇧</span>
        <span class="font-medium tracking-wide">English</span>
        <span class="lang-check ml-auto text-cyan-400 opacity-0 transition-opacity duration-200">✓</span>
      </button>
      <button
        class="lang-option w-full flex items-center gap-3 px-3 py-2.5 text-xs text-slate-300 hover:text-cyan-300 hover:bg-cyan-500/10 rounded-xl transition-all duration-200 text-left cursor-pointer border border-transparent hover:border-cyan-500/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500/50 focus-visible:border-cyan-500/30"
        data-lang="zh-CN"
      >
        <span class="text-base leading-none" aria-hidden="true">🇨🇳</span>
        <span class="font-medium tracking-wide">简体中文</span>
        <span class="lang-check ml-auto text-cyan-400 opacity-0 transition-opacity duration-200">✓</span>
      </button>
    </div>
  </div>
</div>
