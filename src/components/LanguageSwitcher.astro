---
/**
 * Language Switcher Component
 * A sleek dropdown that matches the BINGO site's cosmic dark theme.
 * Shows flags + language names, persists choice in localStorage.
 */
---

<div class="relative" id="lang-switcher" data-no-translate>
  <button
    id="lang-switcher-btn"
    class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-slate-400 hover:text-cyan-400 hover:bg-white/5 transition-all duration-200 text-sm font-medium border border-transparent hover:border-indigo-500/20"
    aria-label="Mudar idioma"
    title="Mudar idioma"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
    </svg>
    <span id="lang-switcher-label" class="hidden sm:inline">PT</span>
    <svg class="w-3 h-3 transition-transform duration-200" id="lang-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div
    id="lang-switcher-menu"
    class="absolute top-full right-0 mt-2 w-44 rounded-xl border border-indigo-500/20 shadow-2xl opacity-0 invisible transition-all duration-200 transform -translate-y-2 z-[100]"
    style="background: rgba(7, 13, 31, 0.97); backdrop-filter: blur(20px);"
    data-no-translate
  >
    <div class="py-2 px-1">
      <button
        class="lang-option w-full flex items-center gap-3 px-4 py-2.5 text-sm text-slate-300 hover:text-cyan-400 hover:bg-white/5 rounded-lg transition-colors text-left"
        data-lang="pt"
      >
        <span class="text-lg leading-none">🇧🇷</span>
        <span>Português</span>
        <span class="lang-check ml-auto text-cyan-400 opacity-0">✓</span>
      </button>
      <button
        class="lang-option w-full flex items-center gap-3 px-4 py-2.5 text-sm text-slate-300 hover:text-cyan-400 hover:bg-white/5 rounded-lg transition-colors text-left"
        data-lang="en"
      >
        <span class="text-lg leading-none">🇬🇧</span>
        <span>English</span>
        <span class="lang-check ml-auto text-cyan-400 opacity-0">✓</span>
      </button>
      <button
        class="lang-option w-full flex items-center gap-3 px-4 py-2.5 text-sm text-slate-300 hover:text-cyan-400 hover:bg-white/5 rounded-lg transition-colors text-left"
        data-lang="zh"
      >
        <span class="text-lg leading-none">🇨🇳</span>
        <span>简体中文</span>
        <span class="lang-check ml-auto text-cyan-400 opacity-0">✓</span>
      </button>
    </div>
  </div>
</div>
