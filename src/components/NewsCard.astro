---
interface Props {
  title: string;
  date: string;
  summary: string;
  image?: string;
  href: string;
}

const { title, date, summary, image, href } = Astro.props;
const base = import.meta.env.BASE_URL;
const imageUrl = image?.startsWith('/') ? `${base}${image.slice(1)}` : image;
---

<a href={href} class="group block h-full rounded-2xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500/50 focus-visible:ring-offset-2 focus-visible:ring-offset-[#070d1f]">
  <article class="news-card bg-slate-900/50 rounded-2xl border border-slate-700/40 overflow-hidden h-full flex flex-col hover:bg-slate-800/60 hover:border-cyan-500/30 hover:shadow-[0_0_30px_rgba(6,182,212,0.08)] transition-all duration-500">
    <div class="h-48 overflow-hidden bg-slate-900 relative">
      {imageUrl ? (
        <img src={imageUrl} alt={title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
      ) : (
        <div class="w-full h-full bg-slate-800/60 flex items-center justify-center">
          <svg class="w-12 h-12 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-transparent to-transparent"></div>
    </div>
    <div class="p-6 flex flex-col flex-grow">
      <time class="text-sm text-cyan-400 font-medium mb-3">{date}</time>
      <h3 class="text-xl font-bold text-white mb-3 leading-tight group-hover:text-cyan-300 transition-colors duration-300">{title}</h3>
      <p class="text-slate-400 text-sm line-clamp-3 mb-4 flex-grow leading-relaxed">{summary}</p>
      <div class="flex items-center text-cyan-400 text-sm font-medium mt-auto">
        <span data-t="news.readmore">Ler mais</span>
        <svg class="ml-2 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </div>
    </div>
  </article>
</a>

